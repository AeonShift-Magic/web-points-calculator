{% extends 'admin/admin_layout.html.twig' %}

{% block title %}{{ 'admin.mtg.pointslistcard.show.title'|trans }}{% endblock %}

{% block main_content %}
    <div class="container mx-auto px-4 py-8">
        <div class="flex justify-between items-center mb-6">
            <h1>{{ 'admin.mtg.pointslistcard.show.heading'|trans }}</h1>
            <div>
                <a href="{{ path('admin_mtg_points_list_card_edit', {'id': points_list_card.id}) }}" class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2 px-4 rounded mr-2">
                    {{ 'admin.mtg.pointslistcard.show.edit'|trans }}
                </a>
                <a href="{{ path('admin_mtg_points_list_card_index') }}" class="bg-gray-600 hover:bg-gray-700 text-white font-bold py-2 px-4 rounded">
                    {{ 'admin.mtg.pointslistcard.show.back'|trans }}
                </a>
            </div>
        </div>

        <div>
            <table class="min-w-full">
                <tbody class="divide-y divide-gray-200">
                    <tr>
                        <th>
                            {{ 'admin.mtg.pointslistcard.show.id'|trans }}
                        </th>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                            {{ points_list_card.id }}
                        </td>
                    </tr>
                    <tr>
                        <th>
                            {{ 'admin.mtg.pointslistcard.show.list'|trans }}
                        </th>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                            {% if points_list_card.pointsList %}
                                <a href="{{ path('admin_mtg_points_list_show', {'id': points_list_card.pointsList.id}) }}" class="text-blue-600 hover:text-blue-800">
                                    {{ points_list_card.pointsList.title }}
                                </a>
                            {% else %}
                                <span>{{ 'admin.mtg.pointslistcard.show.no_list'|trans }}</span>
                            {% endif %}
                        </td>
                    </tr>
                    <tr>
                        <th>
                            {{ 'admin.mtg.pointslistcard.show.name'|trans }}
                        </th>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                            {{ points_list_card.name }}
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
