{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.3",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "ext-zend-opcache": "*",
        "doctrine/dbal": "^3.10.3",
        "doctrine/doctrine-bundle": "^2.18.0",
        "doctrine/doctrine-migrations-bundle": "^3.5.0",
        "doctrine/orm": "^3.5.3",
        "friendsofsymfony/ckeditor-bundle": "^2.6",
        "helios-ag/fm-elfinder-bundle": "^12.7.3",
        "karser/karser-recaptcha3-bundle": ">=0.2.1",
        "knplabs/knp-paginator-bundle": "^6.9.1",
        "liip/imagine-bundle": "^2.15.0",
        "symfony/apache-pack": ">=1.0.1",
        "symfony/asset": "7.3.*",
        "symfony/cache": "7.3.*",
        "symfony/console": "7.3.*",
        "symfony/dotenv": "7.3.*",
        "symfony/flex": "^2.8.2",
        "symfony/framework-bundle": "7.3.*",
        "symfony/google-mailer": "7.3.*",
        "symfony/html-sanitizer": "7.3.*",
        "symfony/http-client": "7.3.*",
        "symfony/intl": "7.3.*",
        "symfony/mailer": "7.3.*",
        "symfony/messenger": "7.3.*",
        "symfony/runtime": "7.3.*",
        "symfony/security-bundle": "7.3.*",
        "symfony/stimulus-bundle": "^2.31.0",
        "symfony/translation": "7.3.*",
        "symfony/twig-bundle": "7.3.*",
        "symfony/uid": "7.3.*",
        "symfony/ux-icons": "^2.31",
        "symfony/ux-live-component": "^2.31",
        "symfony/ux-turbo": "^2.31.0",
        "symfony/ux-twig-component": "^2.31",
        "symfony/validator": "7.3.*",
        "symfony/yaml": "7.3.*",
        "symfonycasts/reset-password-bundle": "^1.23.2",
        "symfonycasts/tailwind-bundle": "^0.10.1",
        "symfonycasts/verify-email-bundle": "^1.17.4",
        "twig/cache-extra": "^3.21",
        "twig/extra-bundle": ">=3.22",
        "twig/intl-extra": "^3.22",
        "twig/string-extra": "^3.22",
        "twig/twig": "^3.21.1"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.89.1",
        "phpstan/extension-installer": "^1.4.3",
        "phpstan/phpstan": "^2.1.31",
        "phpstan/phpstan-doctrine": "^2.0.10",
        "phpstan/phpstan-symfony": "^2.0.8",
        "roave/security-advisories": "dev-latest",
        "symfony/debug-bundle": "7.3.*",
        "symfony/maker-bundle": "^1.64",
        "symfony/stopwatch": "7.3.*",
        "symfony/web-profiler-bundle": "7.3.*",
        "vimeo/psalm": "^6.13.1",
        "weirdan/doctrine-psalm-plugin": "^2.10"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "phpstan/extension-installer": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd",
            "ckeditor:install --tag=4.22.1": "symfony-cmd",
            "elfinder:install": "symfony-cmd",
            "ckeditor:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": "true",
            "require": "7.3.*"
        }
    }
}
