{% extends 'front/front_layout.html.twig' %}

{% block title %}Error 404{% endblock %}

{% block main_layout %}
    <div class="main-row theme1 transluent-row">
        <div class="main-column main-content most-opquage-column">
            <h1>{{ 'global.error.404.title'|trans }}</h1>
            <p class="text-9xl leading-4 my-12">
                404
                <br>
                <img style="height:80px; margin-right: 30px;" height="80px" width="auto" class="inline align-baseline" src="{{ asset('images/aeonshift-logo-transparent.png') }}" alt="DC Logo">
            </p>
            <p>
                {{ 'global.error.404.text'|trans({}, 'messages', 'en') }}
                <br>
                {{ 'global.error.404.text'|trans({}, 'messages', 'fr') }}
            </p>
        </div>
    </div>
{% endblock %}
