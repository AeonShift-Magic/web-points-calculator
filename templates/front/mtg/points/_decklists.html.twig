{# Decklist textareas #}
<div class="flex flex-col w-full justify-around items-start">

    {# Decklist 1 #}
    <div class="flex flex-col lg:flex-row w-full justify-around items-start mt-4" id="decklist-container-1">
        <div class="w-full lg:w-1/3 py-4">
            <div class="mb-8 lg:pr-4 flex flex-col items-center justify center">
                <label for="decklist1">{{ 'front.mtg.form.decklist1.label'|trans }}</label>
                <span id="decklist1-fixed" class="text-sm green-text hidden">
                    <span class="icon-info"></span> {{ 'front.mtg.form.fixeddecklist'|trans|raw }}
                </span>
                <form id="decklist1-add-card" class="w-full card-add-form">
                    <fieldset class="flex flex-col mb-2">
                        <legend class="uppercase text-sm">Add a card</legend>
                        <div class="w-full flex flex-row items-end mb-2">
                            <div class="inline-form-item flex-grow min-w-0">
                                <label for="decklist1-name">{{ 'mtg.name.label'|trans }}</label>
                                <input type="text" name="decklist1-name" id="decklist1-name" value="" placeholder="{{ 'mtg.name.placeholder'|trans }}"/>
                            </div>
                        </div>
                        <div class="w-full flex flex-row items-center gap-2">
                            <div class="inline-form-item flex grow min-w-0">
                                <label for="decklist1-cardzone">{{ 'mtg.cardzones.choose'|trans }}</label>
                                <select required="required" name="decklist1-cardzone" id="decklist1-cardzone" class="w-full">
                                    <option value="commandzone">{{ 'mtg.cardzones.commandzone'|trans }}</option>
                                    <option value="maindeck">{{ 'mtg.cardzones.maindeck'|trans }}</option>
                                    <option value="sideboard">{{ 'mtg.cardzones.sideboard'|trans }}</option>
                                    <option value="companion">{{ 'mtg.cardzones.companion'|trans }}</option>
                                    <option value="attractions">{{ 'mtg.cardzones.attractions'|trans }}</option>
                                    <option value="contraptions">{{ 'mtg.cardzones.contraptions'|trans }}</option>
                                    <option value="stickers">{{ 'mtg.cardzones.stickers'|trans }}</option>
                                </select>
                            </div>
                            <div class="inline-form-item shrink-0 min-w-24">
                                <label for="decklist1-copies">{{ 'mtg.copies.text'|trans }}</label>
                                <input type="number" step="1" min="0" max="100" required="required" name="decklist1-copies" id="decklist1-copies" value="1" class="w-full"/>
                            </div>
                            <div class="inline-form-item shrink-0 min-w-32">
                                <button type="submit" class="btn btn-green w-full" id="decklist1-add">
                                    {{ 'mtg.add.label'|trans }}
                                    <span class="icon-plus"></span>
                                </button>
                            </div>
                        </div>
                    </fieldset>
                </form>
                <textarea class="decklist-cards" rows="30" cols="30" id="decklist1" placeholder="{{ 'front.mtg.form.decklist1.placeholder'|trans|raw }}" data-update-format></textarea>
                <div class="mt-2 help-text text-justify">{{ 'front.mtg.form.decklist1.help'|trans|raw }}</div>
            </div>
        </div>
