{% extends 'admin/admin_layout.html.twig' %}

{% block title %}{{ 'admin.mtg.pointslist.show.title'|trans }}{% endblock %}

{% block main_content %}
    <div class="container mx-auto px-4 py-8">
        <div class="flex justify-between items-center mb-6">
            <h1>{{ 'admin.mtg.pointslist.show.heading'|trans }}</h1>
            <div>
                <a href="{{ path('admin_mtg_points_list_edit', {'id': points_list.id}) }}" class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2 px-4 rounded mr-2">
                    {{ 'admin.mtg.pointslist.show.edit'|trans }}
                </a>
                <a href="{{ path('admin_mtg_points_list_index') }}" class="bg-gray-600 hover:bg-gray-700 text-white font-bold py-2 px-4 rounded">
                    {{ 'admin.mtg.pointslist.show.back'|trans }}
                </a>
            </div>
        </div>

        <div class="bg-white shadow-md rounded-lg overflow-hidden">
            <table class="min-w-full">
                <tbody class="divide-y divide-gray-200">
                    <tr>
                        <th class="px-6 py-4 bg-gray-50 text-left text-sm font-medium text-gray-500 uppercase tracking-wider">
                            {{ 'admin.mtg.pointslist.show.id'|trans }}
                        </th>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                            {{ points_list.id }}
                        </td>
                    </tr>
                    <tr>
                        <th class="px-6 py-4 bg-gray-50 text-left text-sm font-medium text-gray-500 uppercase tracking-wider">
                            {{ 'admin.mtg.pointslist.show.title'|trans }}
                        </th>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                            {{ points_list.title }}
                        </td>
                    </tr>
                    <tr>
                        <th class="px-6 py-4 bg-gray-50 text-left text-sm font-medium text-gray-500 uppercase tracking-wider">
                            {{ 'admin.mtg.pointslist.show.filename'|trans }}
                        </th>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                            {{ points_list.filename }}
                        </td>
                    </tr>
                    <tr>
                        <th class="px-6 py-4 bg-gray-50 text-left text-sm font-medium text-gray-500 uppercase tracking-wider">
                            {{ 'admin.mtg.pointslist.show.cards'|trans }}
                        </th>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                            {{ points_list.nbCards }}
                        </td>
                    </tr>
                    <tr>
                        <th class="px-6 py-4 bg-gray-50 text-left text-sm font-medium text-gray-500 uppercase tracking-wider">
                            {{ 'admin.mtg.pointslist.show.uploaded'|trans }}
                        </th>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                            {{ points_list.lastUploadedAt|date('Y-m-d H:i:s') }}
                        </td>
                    </tr>
                    <tr>
                        <th class="px-6 py-4 bg-gray-50 text-left text-sm font-medium text-gray-500 uppercase tracking-wider">
                            {{ 'admin.mtg.pointslist.show.user'|trans }}
                        </th>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                            {% if points_list.user %}
                                {{ points_list.user.username }}
                            {% else %}
                                <span class="text-gray-400">{{ 'admin.mtg.pointslist.show.no_user'|trans }}</span>
                            {% endif %}
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
