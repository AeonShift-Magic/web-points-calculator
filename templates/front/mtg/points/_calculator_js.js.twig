     * @param {string} text
     * @returns {string}
     */
    const textToOneColumnCsv = (text) => {
        const normalized = String(text ?? '').replace(/\r\n/g, '\n').replace(/\n$/, '');
        const lines = normalized.split('\n');

        const escapeCell = (cell) => {
            const s = String(cell ?? '');
            const escaped = s.replace(/"/g, '""');
            return `"${ escaped }"`;
        };

        return lines.map(line => escapeCell(line)).join('\r\n') + '\r\n';
    };

