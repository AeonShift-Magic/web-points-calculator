    /**
     * Cache choose-commander table DOM once (static bindings).
     */
    const CHOOSE_COMMANDER_TABLE = (() => {
        /** @type {HTMLTableElement|null} */
        let tableEl = null;
        /** @type {HTMLTableSectionElement|null} */
        let tbodyEl = null;
        /** @type {HTMLTableCellElement[]} */
        let headerCells = [];
        /**
         * @type {Array<{rowEl: HTMLTableRowElement, commanderName: string, budgetCellEl: HTMLElement|null}>}
         */
        let rows = [];

        const init = () => {
            tableEl = document.getElementById('choose-commander-table');
            if (!(tableEl instanceof HTMLTableElement)) {
                tableEl = null;
                tbodyEl = null;
                headerCells = [];
                rows = [];
                return;
            }

            tbodyEl = tableEl.tBodies?.[0] ?? null;

            const headerRow = tableEl.tHead?.rows?.[0] ?? null;
            headerCells = headerRow ? Array.from(headerRow.cells) : [];

            rows = [];
            if (!tbodyEl) return;

            const trEls = Array.from(tbodyEl.rows).filter(r => r instanceof HTMLTableRowElement);
            for (const rowEl of trEls) {
                const commanderName = String(rowEl.dataset.commanderName ?? '').trim();
                const budgetCellEl = rowEl.querySelector('[data-field="budget"]');
                rows.push({
                    rowEl,
                    commanderName,
                    budgetCellEl: budgetCellEl instanceof HTMLElement ? budgetCellEl : null
                });
            }
        };

        const getTableEl = () => tableEl;
        const getTbodyEl = () => tbodyEl;
        const getHeaderCells = () => headerCells;
        const getRows = () => rows;

        return { init, getTableEl, getTbodyEl, getHeaderCells, getRows };
    })();

    /**
     * Choose-commander table loader (shown during sorting / heavy table ops).
     * NOTE: must be defined BEFORE initChooseCommanderTableSorting() uses it.
     */
    const CHOOSE_COMMANDER_TABLE_LOADER = (() => {
        /** @type {HTMLDivElement|null} */
        let loaderEl = null;

        const ensure = (tableEl) => {
            if (loaderEl) return loaderEl;

            const host =
                tableEl.closest('.table-wrapper')
                || tableEl.parentElement
                || tableEl;

            if (host instanceof HTMLElement) {
                const computed = window.getComputedStyle(host);
                if (computed.position === 'static') {
                    host.style.position = 'relative';
                }
            }

            loaderEl = document.createElement('div');
            loaderEl.setAttribute('aria-hidden', 'true');
            loaderEl.style.position = 'absolute';
            loaderEl.style.inset = '0';
            loaderEl.style.zIndex = '50';
            loaderEl.style.display = 'none';
            loaderEl.style.alignItems = 'center';
            loaderEl.style.justifyContent = 'center';
            loaderEl.style.background = 'rgba(0, 0, 0, 0.35)';
            loaderEl.style.pointerEvents = 'auto';

            const img = document.createElement('img');
            img.src = '{{ asset('images/loader.gif') }}';
            img.alt = 'Loading';
            img.style.width = '40px';
            img.style.height = '40px';
            img.style.display = 'flex';

            loaderEl.appendChild(img);

            if (host instanceof HTMLElement) {
                host.appendChild(loaderEl);
            } else {
                tableEl.parentElement?.appendChild(loaderEl);
            }

            return loaderEl;
        };

        const show = (tableEl) => {
            const el = ensure(tableEl);
            el.style.display = 'flex';
        };

        const hide = () => {
            if (!loaderEl) return;
            loaderEl.style.display = 'none';
        };

        return { show, hide };
    })();

    /**
     * Choose-commander sorting perf cache.
     * NOTE: must be defined BEFORE any code calls CHOOSE_COMMANDER_SORT.invalidateKey(...)
     */
    const CHOOSE_COMMANDER_SORT = (() => {
        /** @type {WeakMap<HTMLTableRowElement, Map<number, {type:'number'|'string', value:number|string}>>} */
        const keyCacheByRow = new WeakMap();
        const collator = new Intl.Collator(undefined, { numeric: true, sensitivity: 'base' });

        const getRowCache = (rowEl) => {
            let m = keyCacheByRow.get(rowEl);
            if (!m) {
                m = new Map();
                keyCacheByRow.set(rowEl, m);
            }
            return m;
        };

        const parseComparable = (text) => {
            const t = String(text ?? '').trim();

            const numericCandidate = t.replace(/\s+/g, '').replace(/,/g, '.');
            if (/^-?\d+(\.\d+)?$/.test(numericCandidate)) {
                const n = Number(numericCandidate);
                if (Number.isFinite(n)) return { type: 'number', value: n };
            }

            return { type: 'string', value: t.toLocaleLowerCase() };
        };

        const getKey = (rowEl, colIndex) => {
            const cache = getRowCache(rowEl);
            if (cache.has(colIndex)) return cache.get(colIndex);

            const cell = rowEl.children?.[colIndex];
            const key = parseComparable(cell?.textContent ?? '');
            cache.set(colIndex, key);
            return key;
        };

        const invalidateKey = (rowEl, colIndex) => {
            const cache = keyCacheByRow.get(rowEl);
            if (!cache) return;
            cache.delete(colIndex);
        };

        const compareKeys = (ka, kb) => {
            if (ka.type === 'number' && kb.type === 'number') {
                if (ka.value === kb.value) return 0;
                return ka.value < kb.value ? -1 : 1;
            }
            return collator.compare(String(ka.value), String(kb.value));
        };

        return { getKey, invalidateKey, compareKeys };
    })();

    /**
     * Sort rows of #choose-commander-table by a column index and direction.
     *
     * @param {HTMLTableElement} tableEl
     * @param {number} colIndex
     * @param {'asc'|'desc'} direction
     */
    const sortChooseCommanderTable = (tableEl, colIndex, direction) => {
        const tbody = tableEl.tBodies?.[0];
        if (!tbody) return;

        const dir = direction === 'desc' ? -1 : 1;

        /** @type {HTMLTableRowElement[]} */
        const rows = Array.from(tbody.rows).filter(r => r instanceof HTMLTableRowElement);
        if (rows.length <= 1) return;

        // The "Color Identity" column is icons in the cell, but the sortable value is stored on the row.
        const COLOR_IDENTITY_COL_INDEX = 6;

        const filterFormEl = document.getElementById('choose-commander-filter');
        const selectedIdentity = (() => {
            if (!(filterFormEl instanceof HTMLFormElement)) return '';

            const checked = Array
                .from(filterFormEl.querySelectorAll('input[type="checkbox"][data-update-commanders][data-color]'))
                .filter(el => el instanceof HTMLInputElement && el.checked)
                .map(el => String(el.value ?? '').trim().toUpperCase())
                .filter(Boolean);

            if (checked.length === 0) return '';

            const set = new Set(checked);
            // Canonical order for identity strings
            const order = ['W', 'U', 'B', 'R', 'G', 'C'];
            return order.filter(c => set.has(c)).join('');
        })();

        const decorated = rows.map((rowEl, idx) => {
            if (colIndex === COLOR_IDENTITY_COL_INDEX) {
                const identity = String(rowEl.dataset.colorIdentity ?? '').trim().toUpperCase();
                return {
                    rowEl,
                    idx,
                    key: CHOOSE_COMMANDER_SORT.getKey(rowEl, colIndex),
                    colorIdentity: identity
                };
            }

            return {
                rowEl,
                idx,
                key: CHOOSE_COMMANDER_SORT.getKey(rowEl, colIndex)
            };
        });

        const isEmptyKey = (k) => {
            if (!k) return true;
            if (k.type === 'string') return String(k.value ?? '').trim() === '';
            if (k.type === 'number') return !Number.isFinite(Number(k.value));
            return true;
        };

        decorated.sort((a, b) => {
            // Always push empty cells to the bottom (regardless of ASC/DESC)
            const aEmpty = isEmptyKey(a.key);
            const bEmpty = isEmptyKey(b.key);
            if (aEmpty !== bEmpty) return aEmpty ? 1 : -1;

            // Color identity sorting:
            // If the user selected colors, put rows that CONTAIN ALL selected colors first.
            // Then: 1) by size (len), 2) by canonical identity string (WUBRGC presence order).
            if (colIndex === COLOR_IDENTITY_COL_INDEX) {
                const aId = String(a.colorIdentity ?? '').trim().toUpperCase();
                const bId = String(b.colorIdentity ?? '').trim().toUpperCase();

                if (selectedIdentity !== '') {
                    const aMatches = selectedIdentity.split('').every(c => aId.includes(c));
                    const bMatches = selectedIdentity.split('').every(c => bId.includes(c));
                    if (aMatches !== bMatches) return aMatches ? -1 : 1;
                }

                if (aId.length !== bId.length) {
                    return (aId.length < bId.length ? -1 : 1) * dir;
                }

                if (aId !== bId) {
                    return (aId < bId ? -1 : 1) * dir;
                }

                return a.idx - b.idx;
            }

            const r = CHOOSE_COMMANDER_SORT.compareKeys(a.key, b.key);
            if (r === 0) return a.idx - b.idx;
            return r * dir;
        });

        let changed = false;
        for (let i = 0; i < decorated.length; i++) {
            if (decorated[i].rowEl !== rows[i]) {
                changed = true;
                break;
            }
        }
        if (!changed) {
            tableEl.dataset.sortCol = String(colIndex);
            tableEl.dataset.sortDir = direction;
            return;
        }

        const frag = document.createDocumentFragment();
        for (const item of decorated) frag.appendChild(item.rowEl);
        tbody.appendChild(frag);

        tableEl.dataset.sortCol = String(colIndex);
        tableEl.dataset.sortDir = direction;
    };

    /**
     * Make the #choose-commander-table headers clickable to sort ASC/DESC.
     */
    const initChooseCommanderTableSorting = () => {
        const tableEl = CHOOSE_COMMANDER_TABLE.getTableEl();
        if (!(tableEl instanceof HTMLTableElement)) return;

        const headers = CHOOSE_COMMANDER_TABLE.getHeaderCells();
        if (!Array.isArray(headers) || headers.length === 0) return;

        headers.forEach((th, index) => {
            th.style.cursor = 'pointer';
            th.setAttribute('role', 'button');
            th.setAttribute('tabindex', '0');

            const activate = () => {
                const currentCol = Number(tableEl.dataset.sortCol ?? -1);
                const currentDir = String(tableEl.dataset.sortDir ?? 'asc');

                const nextDir =
                    currentCol === index
                        ? (currentDir === 'asc' ? 'desc' : 'asc')
                        : 'asc';

                headers.forEach(h => h.removeAttribute('aria-sort'));
                th.setAttribute('aria-sort', nextDir === 'asc' ? 'ascending' : 'descending');

                CHOOSE_COMMANDER_TABLE_LOADER.show(tableEl);

                // Force a reflow so the browser commits the "display:flex" before we block the thread.
                const loaderHost = tableEl.closest('.table-wrapper') || tableEl.parentElement || tableEl;
                if (loaderHost instanceof HTMLElement) {
                    void loaderHost.offsetHeight;
                }

                // Yield to allow paint (GIF animates), then do the heavy synchronous sort.
                window.setTimeout(() => {
                    try {
                        sortChooseCommanderTable(tableEl, index, nextDir);
                    } finally {
                        CHOOSE_COMMANDER_TABLE_LOADER.hide();
                    }
                }, 0);
            };

            th.addEventListener('click', activate);
            th.addEventListener('keydown', (e) => {
                if (e.key === 'Enter' || e.key === ' ') {
                    e.preventDefault();
                    activate();
                }
            });
        });
    };

    /**
     * Recalculate and update the "budget" cell for each row of #choose-commander-table,
     * using the current update's calculatorJsFunctionPrefix ApplyModulations().
     */
    const recalculateChooseCommanderTableBudgets = () => {
        const tableEl = document.getElementById('choose-commander-table');
        if (!(tableEl instanceof HTMLTableElement)) return;

        const tbody = tableEl.tBodies?.[0];
        if (!tbody) return;

        const currentFormatChoiceValues = getCurrentFormatChoiceValues();

        const calculatorJsFunctionPrefix =
            updates?.updates?.[currentFormatChoiceValues.update]?.pointsList?.calculatorJsFunctionPrefix ?? null;

        if (typeof calculatorJsFunctionPrefix !== 'string' || calculatorJsFunctionPrefix.trim() === '') {
            return;
        }

        const getPValueFn = window[calculatorJsFunctionPrefix + 'GetPValueFromFormFields'];
        const applyModulationsFn = window[calculatorJsFunctionPrefix + 'ApplyModulations'];
        const calculatePointsFn = window[calculatorJsFunctionPrefix + 'ApplyPoints'];

        if (typeof getPValueFn !== 'function' || typeof applyModulationsFn !== 'function') {
            return;
        }

        const pvalue = Number(getPValueFn(updates, currentFormatChoiceValues));
        if (!Number.isFinite(pvalue)) return;

        // Determine budget column index once (based on header count; budget is 2nd column in template)
        const budgetColIndex = 1;
        // Status is 3rd column in template (0=name, 1=budget, 2=status)
        const statusColIndex = 2;

        const selectedUpdateStartingAtTimestamp =
            Number(updates?.updates?.[currentFormatChoiceValues.update]?.startingAtTimestamp ?? NaN);

        /**
         * Parse row's data-first-printed-at into a millisecond timestamp (best-effort).
         *
         * Accepts ISO-ish strings (e.g. 2025-11-21T00:00:00Z) and falls back to YYYY-MM-DD only.
         *
         * @param {string} raw
         * @returns {number|null}
         */
        const parseFirstPrintedAtMs = (raw) => {
            const s = String(raw ?? '').trim();
            if (!s) return null;

            const direct = Date.parse(s);
            if (Number.isFinite(direct)) return direct;

            // Fallback: take YYYY-MM-DD and interpret as UTC midnight
            const m = s.match(/^(\d{4}-\d{2}-\d{2})/);
            if (!m) return null;

            const d2 = Date.parse(m[1] + 'T00:00:00Z');
            return Number.isFinite(d2) ? d2 : null;
        };

        /** @type {HTMLTableRowElement[]} */
        const rows = Array.from(tbody.rows).filter(r => r instanceof HTMLTableRowElement);

        for (const rowEl of rows) {
            const commanderName = String(rowEl.dataset.commanderName ?? '').trim();
            if (!commanderName) continue;

            const deckListStructure = {
                total: 1,
                maindeck: [],
                commandzone: [{ copies: 1, name: commanderName, points: null, imageurl: '' }],
                sideboard: [],
                companions: [],
                attractions: [],
                contraptions: [],
                stickers: [],
                modulations: [],
                breakdown: [],
                errors: [],
                budget: pvalue,
                remaining: pvalue,
                mvalue: 0.0,
                mvalues: [],
                pvalue: pvalue
            };

            applyModulationsFn(deckListStructure, currentFormatChoiceValues, pvalue);
            calculatePointsFn(deckListStructure, currentFormatChoiceValues, pvalue);

            if (deckListStructure?.budget !== null && typeof deckListStructure?.budget !== 'undefined') {
                const budgetCell = rowEl.querySelector('[data-field="budget"]');
                if (budgetCell) {
                    const nextBudgetText = String(deckListStructure.budget);
                    if (budgetCell.textContent !== nextBudgetText) {
                        budgetCell.textContent = nextBudgetText;
                        // Budget changed -> invalidate sort cache for that cell only
                        CHOOSE_COMMANDER_SORT.invalidateKey(rowEl, budgetColIndex);
                    }
                }
            }

            // Update "status" based on whether the current update predates the card's first print.
            if (Number.isFinite(selectedUpdateStartingAtTimestamp)) {
                const firstPrintedAtRaw = String(rowEl.dataset.firstPrintedAt ?? '').trim();
                const firstPrintedAtMs = parseFirstPrintedAtMs(firstPrintedAtRaw);

                if (firstPrintedAtMs !== null) {
                    const updateMs = selectedUpdateStartingAtTimestamp * 1000;
                    const nextStatusHtml = updateMs < firstPrintedAtMs ? MESSAGES.unranked : MESSAGES.released;

                    const statusCell = rowEl.querySelector('[data-field="status"]');
                    if (statusCell && statusCell.innerHTML !== nextStatusHtml) {
                        statusCell.innerHTML = nextStatusHtml;
                        // Status changed -> invalidate sort cache for that cell only
                        CHOOSE_COMMANDER_SORT.invalidateKey(rowEl, statusColIndex);
                    }
                }
            }
        }

        // If a sort is active, re-apply it (budgets may have changed)
        const sortCol = Number(tableEl.dataset.sortCol ?? -1);
        const sortDir = String(tableEl.dataset.sortDir ?? '');
        if (Number.isFinite(sortCol) && sortCol >= 0 && (sortDir === 'asc' || sortDir === 'desc')) {
            window.requestAnimationFrame(() => {
                try {
                    CHOOSE_COMMANDER_TABLE_LOADER.show(tableEl);
                    sortChooseCommanderTable(tableEl, sortCol, sortDir);
                } finally {
                    CHOOSE_COMMANDER_TABLE_LOADER.hide();
                }
            });
        }

        // Budget changes can affect filtering -> re-apply filters.
        applyChooseCommanderFilters();
    };

    /**
     * Apply filters from the "#choose-commander-filter" form to rows of #choose-commander-table
     * by toggling the "filtered-out" class on <tr>.
     */
    const applyChooseCommanderFilters = () => {
        const tableEl = CHOOSE_COMMANDER_TABLE.getTableEl();
        if (!(tableEl instanceof HTMLTableElement)) return;

        const filterFormEl = document.getElementById('choose-commander-filter');
        if (!(filterFormEl instanceof HTMLFormElement)) return;

        const nameInputEl = /** @type {HTMLInputElement|null} */ (filterFormEl.querySelector('#choose-commander-name'));
        const budgetInputEl = /** @type {HTMLInputElement|null} */ (filterFormEl.querySelector('#choose-commander-budget'));
        const duelSelectEl = /** @type {HTMLSelectElement|null} */ (filterFormEl.querySelector('#choose-commander-duel-ranking'));
        const cedhSelectEl = /** @type {HTMLSelectElement|null} */ (filterFormEl.querySelector('#choose-commander-cedh-ranking'));
        const ffaSelectEl = /** @type {HTMLSelectElement|null} */ (filterFormEl.querySelector('#choose-commander-ffa-ranking'));

        const selectedName = String(nameInputEl?.value ?? '').trim().toLocaleLowerCase();
        const shouldFilterName = selectedName.length >= 2;

        const rawBudget = String(budgetInputEl?.value ?? '').trim();
        const budgetValue = rawBudget === '' ? null : Number(rawBudget);
        const shouldFilterBudget = budgetValue !== null && Number.isFinite(budgetValue) && budgetValue >= 0;

        const currentFormatChoiceValues = getCurrentFormatChoiceValues();

        // Resolve precedences map once for this apply pass.
        const updateKey = currentFormatChoiceValues?.update;
        const precedences = updates?.updates?.[updateKey]?.pointsList?.timelineprecedences ?? null;

        /**
         * Resolve the currently selected timeline precedence integer from the updates config.
         *
         * timelineprecedences is expected to be a mapping:
         *   { [timelineKey: string]: number, ... }
         *
         * @returns {number|null}
         */
        const getSelectedTimelinePrecedence = () => {
            const timelineKey = String(currentFormatChoiceValues?.timeline ?? '').trim();
            if (!timelineKey) return null;

            if (!precedences || typeof precedences !== 'object' || Array.isArray(precedences)) {
                return null;
            }

            if (!Object.prototype.hasOwnProperty.call(precedences, timelineKey)) {
                return null;
            }

            const n = Number(precedences[timelineKey]);
            return Number.isFinite(n) ? n : null;
        };

        const selectedTimelinePrecedence = getSelectedTimelinePrecedence();

        const toRankScore = (v) => {
            switch (String(v ?? '').trim()) {
                case 'top':
                    return 0;
                case 'popular':
                    return 1;
                case 'alltournamentranked':
                    return 2;
                case 'all':
                    return 3;
                default:
                    return 3;
            }
        };

        const selectedDuelScore = toRankScore(duelSelectEl?.value);
        const selectedCedhScore = toRankScore(cedhSelectEl?.value);
        const selectedFfaScore = toRankScore(ffaSelectEl?.value);

        const checkedColorAttrNames = Array
            .from(filterFormEl.querySelectorAll('input[type="checkbox"][data-update-commanders][data-color]'))
            .filter(el => el instanceof HTMLInputElement && el.checked)
            .map(el => String(el.dataset.color ?? '').trim())
            .filter(Boolean);

        const rowMatchesRank = (rowEl, datasetKey, selectedScore) => {
            if (selectedScore >= 3) return true; // "all" => no filtering
            const rowScore = toRankScore(rowEl.dataset?.[datasetKey]);
            return rowScore <= selectedScore; // keep selected OR better (top is best)
        };

        for (const r of CHOOSE_COMMANDER_TABLE.getRows()) {
            const rowEl = r.rowEl;

            let ok = true;

            if (shouldFilterName) {
                const rowName = String(r.commanderName ?? '').toLocaleLowerCase();
                ok = ok && rowName.includes(selectedName);
            }

            if (shouldFilterBudget) {
                const cellText = String(r.budgetCellEl?.textContent ?? '').trim();
                const rowBudget = Number(cellText);
                ok = ok && Number.isFinite(rowBudget) && rowBudget >= budgetValue;
            }

            ok = ok && rowMatchesRank(rowEl, 'rankingDuelClass', selectedDuelScore);
            ok = ok && rowMatchesRank(rowEl, 'rankingCedhClass', selectedCedhScore);
            ok = ok && rowMatchesRank(rowEl, 'rankingFfaClass', selectedFfaScore);

            if (ok && checkedColorAttrNames.length > 0) {
                for (const attrName of checkedColorAttrNames) {
                    if (rowEl.getAttribute(attrName) === null) {
                        ok = false;
                        break;
                    }
                }
            }

            if (
                ok
                && selectedTimelinePrecedence !== null
                && precedences
                && typeof precedences === 'object'
                && !Array.isArray(precedences)
            ) {
                // <tr data-maximum-timeline="funny"> -> dataset.maximumTimeline === "funny"
                const rowMaximumTimelineKey = String(rowEl.dataset.maximumTimeline ?? '').trim();
                if (rowMaximumTimelineKey !== '' && Object.prototype.hasOwnProperty.call(precedences, rowMaximumTimelineKey)) {
                    const rowMaximumTimelinePrecedence = Number(precedences[rowMaximumTimelineKey]);
                    if (Number.isFinite(rowMaximumTimelinePrecedence)) {
                        // Filter OUT rows where max-timeline precedence is >= selected timeline precedence
                        if (rowMaximumTimelinePrecedence < selectedTimelinePrecedence) {
                            ok = false;
                        }
                    }
                }
            }

            rowEl.classList.toggle('filtered-out', !ok);
        }
    };

    /**
     * Bind filtering to all [data-update-commanders] fields:
     * - immediate update on change for selects/checkboxes/number
     * - throttled typing for commander name (min 2 chars to trigger filtering)
     */
    const initChooseCommanderTableFiltering = () => {
        const filterFormEl = document.getElementById('choose-commander-filter');
        if (!(filterFormEl instanceof HTMLFormElement)) return;

        const fields = Array.from(filterFormEl.querySelectorAll('[data-update-commanders]'));

        const nameInputEl = filterFormEl.querySelector('#choose-commander-name');
        let nameTimer = /** @type {number|null} */ (null);

        const scheduleNameFilter = () => {
            if (nameTimer !== null) {
                window.clearTimeout(nameTimer);
            }
            nameTimer = window.setTimeout(() => {
                nameTimer = null;
                applyChooseCommanderFilters();
            }, 150);
        };

        for (const el of fields) {
            if (!(el instanceof HTMLElement)) continue;

            if (el === nameInputEl) {
                el.addEventListener('input', scheduleNameFilter);
                el.addEventListener('change', scheduleNameFilter);
                continue;
            }

            // Everything else: update immediately
            el.addEventListener('change', applyChooseCommanderFilters);

            // "number" inputs usually fire input events while dragging/spinning
            if (el instanceof HTMLInputElement && el.type === 'number') {
                el.addEventListener('input', applyChooseCommanderFilters);
            }
        }

        // Initial pass (also covers default selected rankings, default budget, etc.)
        applyChooseCommanderFilters();
    };

    /**
     * Show the "Choose a Commander" block if Command Zones are used.
     */
    const updateChooseCommanderVisibility = () => {
        if (!commanderChoiceContainerEl) return;

        const shouldShow = !!(commanderYesEl && commanderYesEl.checked);
        commanderChoiceContainerEl.classList.remove('hidden-form');

        for (const el of chooseCommanderIncentiveEls) {
            if (el instanceof HTMLElement) {
                el.classList.remove('hidden-form');
            }
        }

        if (shouldShow === false) {
            commanderChoiceContainerEl.classList.add('hidden-form');

            for (const el of chooseCommanderIncentiveEls) {
                if (el instanceof HTMLElement) {
                    el.classList.add('hidden-form');
                }
            }
        }
    };

    /**
     * Cache choose-cards table DOM (rows are dynamic; call init() after rendering).
     */
    const CHOOSE_CARDS_TABLE = (() => {
        /** @type {HTMLTableElement|null} */
        let tableEl = null;
        /** @type {HTMLTableSectionElement|null} */
        let tbodyEl = null;
        /**
         * @type {Array<{rowEl: HTMLTableRowElement, cardName: string}>}
         */
        let rows = [];

        const init = () => {
            tableEl = document.getElementById('choose-cards-table');
            if (!(tableEl instanceof HTMLTableElement)) {
                tableEl = null;
                tbodyEl = null;
                rows = [];
                return;
            }

            tbodyEl = tableEl.tBodies?.[0] ?? null;

            rows = [];
            if (!tbodyEl) return;

            const trEls = Array.from(tbodyEl.rows).filter(r => r instanceof HTMLTableRowElement);
            for (const rowEl of trEls) {
                const fromDataset = String(rowEl.dataset.cardName ?? '').trim();
                const fromCell = String(rowEl.cells?.[0]?.textContent ?? '').trim();
                rows.push({
                    rowEl,
                    cardName: fromDataset || fromCell
                });
            }
        };

        const getTableEl = () => tableEl;
        const getRows = () => rows;

        return { init, getTableEl, getRows };
    })();

    /**
     * Choose-cards sorting perf cache (same approach as CHOOSE_COMMANDER_SORT).
     */
    const CHOOSE_CARDS_SORT = (() => {
        /** @type {WeakMap<HTMLTableRowElement, Map<number, {type:'number'|'string', value:number|string}>>} */
        const keyCacheByRow = new WeakMap();
        const collator = new Intl.Collator(undefined, { numeric: true, sensitivity: 'base' });

        const getRowCache = (rowEl) => {
            let m = keyCacheByRow.get(rowEl);
            if (!m) {
                m = new Map();
                keyCacheByRow.set(rowEl, m);
            }
            return m;
        };

        const parseComparable = (text) => {
            const t = String(text ?? '').trim();

            const numericCandidate = t.replace(/\s+/g, '').replace(/,/g, '.');
            if (/^-?\d+(\.\d+)?$/.test(numericCandidate)) {
                const n = Number(numericCandidate);
                if (Number.isFinite(n)) return { type: 'number', value: n };
            }

            return { type: 'string', value: t.toLocaleLowerCase() };
        };

        const getKey = (rowEl, colIndex) => {
            const cache = getRowCache(rowEl);
            if (cache.has(colIndex)) return cache.get(colIndex);

            const cell = rowEl.children?.[colIndex];
            const key = parseComparable(cell?.textContent ?? '');
            cache.set(colIndex, key);
            return key;
        };

        const compareKeys = (ka, kb) => {
            if (ka.type === 'number' && kb.type === 'number') {
                if (ka.value === kb.value) return 0;
                return ka.value < kb.value ? -1 : 1;
            }
            return collator.compare(String(ka.value), String(kb.value));
        };

        return { getKey, compareKeys };
    })();

    /**
     * Apply filters from the "#choose-card-filter" form to rows of #choose-cards-table
     * by toggling the "filtered-out" class on <tr>.
     *
     * Filters:
     * - Name (#choose-card-name, min 2 chars)
     * - Color identity (checkboxes name="choose-card-color-identity[]")
     */
    const applyChooseCardsFilters = () => {
        const tableEl = CHOOSE_CARDS_TABLE.getTableEl();
        if (!(tableEl instanceof HTMLTableElement)) return;

        const filterFormEl = document.getElementById('choose-card-filter');
        if (!(filterFormEl instanceof HTMLFormElement)) return;

        const nameInputEl = /** @type {HTMLInputElement|null} */ (filterFormEl.querySelector('#choose-card-name'));

        const selectedName = String(nameInputEl?.value ?? '').trim().toLocaleLowerCase();
        const shouldFilterName = selectedName.length >= 2;

        const selectedColors = Array
            .from(filterFormEl.querySelectorAll('input[type="checkbox"][name="choose-card-color-identity[]"]'))
            .filter(el => el instanceof HTMLInputElement && el.checked)
            .map(el => String(el.value ?? '').trim().toUpperCase())
            .filter(Boolean);

        for (const r of CHOOSE_CARDS_TABLE.getRows()) {
            const rowEl = r.rowEl;

            let keepRow = true;

            if (shouldFilterName) {
                const rowName = String(r.cardName ?? '').toLocaleLowerCase();
                keepRow = keepRow && rowName.includes(selectedName);
            }

            if (keepRow && selectedColors.length > 0) {
                const colorIdentityAttribute = String(
                    rowEl.getAttribute('data-color-identity')
                    ?? rowEl.dataset.colorIdentity
                    ?? ''
                ).trim().toUpperCase();

                for (const selectedColor of selectedColors) {
                    if (!colorIdentityAttribute.includes(selectedColor)) {
                        keepRow = false;
                        break;
                    }
                }
            }

            rowEl.classList.toggle('filtered-out', !keepRow);
        }
    };

    /**
     * Sort rows of #choose-cards-table by a column index and direction.
     *
     * Column indexes in choose-cards-table:
     * 0 = Name, 1 = Points, 2 = cEDH rank, 3 = MV, 4 = Color Identity
     *
     * @param {HTMLTableElement} tableEl
     * @param {number} colIndex
     * @param {'asc'|'desc'} direction
     */
    const sortChooseCardsTable = (tableEl, colIndex, direction) => {
        const tbody = tableEl.tBodies?.[0];
        if (!tbody) return;

        const dir = direction === 'desc' ? -1 : 1;

        /** @type {HTMLTableRowElement[]} */
        const rows = Array.from(tbody.rows).filter(r => r instanceof HTMLTableRowElement);
        if (rows.length <= 1) return;

        const COLOR_IDENTITY_COL_INDEX = 4;

        const filterFormEl = document.getElementById('choose-card-filter');
        const selectedIdentity = (() => {
            if (!(filterFormEl instanceof HTMLFormElement)) return '';

            const checked = Array
                .from(filterFormEl.querySelectorAll('input[type="checkbox"][name="choose-card-color-identity[]"]'))
                .filter(el => el instanceof HTMLInputElement && el.checked)
                .map(el => String(el.value ?? '').trim().toUpperCase())
                .filter(Boolean);

            if (checked.length === 0) return '';

            const set = new Set(checked);
            const order = ['W', 'U', 'B', 'R', 'G', 'C'];
            return order.filter(c => set.has(c)).join('');
        })();

        const canonicalizeIdentity = (raw) => {
            const s = String(raw ?? '').trim().toUpperCase();
            if (s === '') return '';

            const set = new Set(s.split('').filter(Boolean));
            const order = ['W', 'U', 'B', 'R', 'G', 'C'];
            return order.filter(c => set.has(c)).join('');
        };

        const decorated = rows.map((rowEl, idx) => {
            if (colIndex === COLOR_IDENTITY_COL_INDEX) {
                const raw = String(
                    rowEl.getAttribute('data-color-identity')
                    ?? rowEl.dataset.colorIdentity
                    ?? ''
                );
                return {
                    rowEl,
                    idx,
                    key: CHOOSE_CARDS_SORT.getKey(rowEl, colIndex),
                    colorIdentity: canonicalizeIdentity(raw)
                };
            }

            return {
                rowEl,
                idx,
                key: CHOOSE_CARDS_SORT.getKey(rowEl, colIndex)
            };
        });

        const isEmptyKey = (k) => {
            if (!k) return true;
            if (k.type === 'string') return String(k.value ?? '').trim() === '';
            if (k.type === 'number') return !Number.isFinite(Number(k.value));
            return true;
        };

        decorated.sort((a, b) => {
            // Always push empty cells to the bottom (regardless of ASC/DESC)
            const aEmpty = isEmptyKey(a.key);
            const bEmpty = isEmptyKey(b.key);
            if (aEmpty !== bEmpty) return aEmpty ? 1 : -1;

            if (colIndex === COLOR_IDENTITY_COL_INDEX) {
                const aId = String(a.colorIdentity ?? '').trim().toUpperCase();
                const bId = String(b.colorIdentity ?? '').trim().toUpperCase();

                if (selectedIdentity !== '') {
                    const aMatches = selectedIdentity.split('').every(c => aId.includes(c));
                    const bMatches = selectedIdentity.split('').every(c => bId.includes(c));
                    if (aMatches !== bMatches) return aMatches ? -1 : 1;
                }

                if (aId.length !== bId.length) {
                    return (aId.length < bId.length ? -1 : 1) * dir;
                }

                if (aId !== bId) {
                    return (aId < bId ? -1 : 1) * dir;
                }

                return a.idx - b.idx;
            }

            const r = CHOOSE_CARDS_SORT.compareKeys(a.key, b.key);
            if (r === 0) return a.idx - b.idx;
            return r * dir;
        });

        let changed = false;
        for (let i = 0; i < decorated.length; i++) {
            if (decorated[i].rowEl !== rows[i]) {
                changed = true;
                break;
            }
        }
        if (!changed) {
            tableEl.dataset.sortCol = String(colIndex);
            tableEl.dataset.sortDir = direction;
            return;
        }

        const frag = document.createDocumentFragment();
        for (const item of decorated) frag.appendChild(item.rowEl);
        tbody.appendChild(frag);

        tableEl.dataset.sortCol = String(colIndex);
        tableEl.dataset.sortDir = direction;
    };

    /**
     * Make the #choose-cards-table headers clickable to sort ASC/DESC.
     * Safe to call multiple times (guards against double-binding).
     */
    const initChooseCardsTableSorting = () => {
        const tableEl = document.getElementById('choose-cards-table');
        if (!(tableEl instanceof HTMLTableElement)) return;

        if (tableEl.dataset.chooseCardsSortBound === '1') return;
        tableEl.dataset.chooseCardsSortBound = '1';

        const headerRow = tableEl.tHead?.rows?.[0] ?? null;
        const headers = headerRow ? Array.from(headerRow.cells) : [];
        if (headers.length === 0) return;

        headers.forEach((th, index) => {
            th.style.cursor = 'pointer';
            th.setAttribute('role', 'button');
            th.setAttribute('tabindex', '0');

            const activate = () => {
                const currentCol = Number(tableEl.dataset.sortCol ?? -1);
                const currentDir = String(tableEl.dataset.sortDir ?? 'asc');

                const nextDir =
                    currentCol === index
                        ? (currentDir === 'asc' ? 'desc' : 'asc')
                        : 'asc';

                headers.forEach(h => h.removeAttribute('aria-sort'));
                th.setAttribute('aria-sort', nextDir === 'asc' ? 'ascending' : 'descending');

                // Reuse existing loader helper (it's generic enough even if named "COMMANDER")
                CHOOSE_COMMANDER_TABLE_LOADER.show(tableEl);

                const loaderHost = tableEl.closest('.table-wrapper') || tableEl.parentElement || tableEl;
                if (loaderHost instanceof HTMLElement) {
                    void loaderHost.offsetHeight;
                }

                window.setTimeout(() => {
                    try {
                        sortChooseCardsTable(tableEl, index, nextDir);
                    } finally {
                        CHOOSE_COMMANDER_TABLE_LOADER.hide();
                    }
                }, 0);
            };

            th.addEventListener('click', activate);
            th.addEventListener('keydown', (e) => {
                if (e.key === 'Enter' || e.key === ' ') {
                    e.preventDefault();
                    activate();
                }
            });
        });
    };

    /**
     * Bind filtering to all [data-update-card-rankings] fields:
     * - throttled typing for card name (min 2 chars)
     * - immediate update on checkbox changes
     *
     * Safe to call multiple times (guards against double-binding).
     */
    const initChooseCardsTableFiltering = () => {
        const filterFormEl = document.getElementById('choose-card-filter');
        if (!(filterFormEl instanceof HTMLFormElement)) return;

        if (filterFormEl.dataset.chooseCardsFilterBound === '1') {
            return;
        }
        filterFormEl.dataset.chooseCardsFilterBound = '1';

        const fields = Array.from(filterFormEl.querySelectorAll('[data-update-card-rankings]'));

        const nameInputEl = filterFormEl.querySelector('#choose-card-name');
        let nameTimer = /** @type {number|null} */ (null);

        const scheduleNameFilter = () => {
            if (nameTimer !== null) {
                window.clearTimeout(nameTimer);
            }
            nameTimer = window.setTimeout(() => {
                nameTimer = null;
                applyChooseCardsFilters();
            }, 150);
        };

        for (const el of fields) {
            if (!(el instanceof HTMLElement)) continue;

            if (el === nameInputEl) {
                el.addEventListener('input', scheduleNameFilter);
                el.addEventListener('change', scheduleNameFilter);
                continue;
            }

            el.addEventListener('change', applyChooseCardsFilters);
        }

        applyChooseCardsFilters();
    };

    /**
     * Parse an MTGO-like decklist textarea into zone -> [{copies, name}]
     *
     * Expected input (as produced by this page):
     * Zone name
     * 1 Card Name
     * 2 Another Card
     *
     * @param {string} raw
     * @returns {Record<string, {zoneLabel: string, cards: Array<{copies: number, name: string}>}>}
     */
    const parseDecklistTextareaToZones = (raw) => {
        const out = Object.create(null);

        // Map of textarea headings (current UI) -> "canonical label" we will print
        const knownZoneHeadings = new Map([
            ['Commander', 'Commander'],
            ['Companion', 'Companion'],
            ['Maindeck', 'Maindeck'],
            ['Sideboard', 'Sideboard'],
            ['Attractions', 'Attractions'],
            ['Stickers', 'Stickers'],
            ['Contraptions', 'Contraptions']
        ]);

        const normalized = String(raw ?? '').replace(/\r\n/g, '\n');
        const lines = normalized.split('\n').map(l => l.trim()).filter(l => l !== '');

        /** @type {string|null} */
        let currentZoneLabel = null;

        const ensureZone = (zoneLabel) => {
            if (!out[zoneLabel]) {
                out[zoneLabel] = { zoneLabel, cards: [] };
            }
            return out[zoneLabel];
        };

        for (const line of lines) {
            // Zone heading?
            if (knownZoneHeadings.has(line)) {
                currentZoneLabel = knownZoneHeadings.get(line);
                ensureZone(currentZoneLabel);
                continue;
            }

            // Card line?
            // Accept: "N Name..." (N = integer)
            const m = line.match(/^(\d+)\s+(.+)$/);
            if (!m) {
                continue;
            }

            const copies = Number(m[1]);
            const name = String(m[2] ?? '').trim();

            if (!Number.isFinite(copies) || copies <= 0) continue;
            if (!name) continue;
            if (!currentZoneLabel) continue; // ignore cards before first zone heading

            ensureZone(currentZoneLabel).cards.push({ copies, name });
        }

        return out;
    };

    /**
     * Build the requested downloadable text output:
     * - player's name
     * - (optional) comment
     * - format short (full)
     * - generation date
     * - per non-empty zone: "Zone (N)" then each card "[___] q name"
     *
     * @param {string} playerName
     * @param {string} comment
     * @param {string} decklistRaw
     * @returns {string}
     */
    const buildDecklistDownloadText = (playerName, comment, decklistRaw) => {
        const safePlayer = String(playerName ?? '').trim();
        const safeComment = String(comment ?? '').trim();

        const shortName = String(formatNameEl?.textContent ?? '').trim();
        const fullName = String(formatFullNameEl?.textContent ?? '').trim();

        const shortPart = shortName || 'AeonShift';
        const fullPart = fullName || shortPart;

        const generatedAt = formatLocalDateTime(new Date());

        const zones = parseDecklistTextareaToZones(decklistRaw);

        // Canonical order
        const zoneOrder = ['Commander', 'Companion', 'Maindeck', 'Sideboard', 'Attractions', 'Stickers', 'Contraptions'];

        const lines = [];
        lines.push('-------------------------------------------------------------------------------------------------');
        lines.push(`Player: ${ safePlayer }`);
        lines.push('-------------------------------------------------------------------------------------------------');
        lines.push('');

        if (safeComment !== '') {
            lines.push('-------------------------------------------------------------------------------------------------');
            lines.push(safeComment);
            lines.push('-------------------------------------------------------------------------------------------------');
            lines.push('');
        }

        lines.push('-------------------------------------------------------------------------------------------------');
        lines.push(`Format: ${ shortPart } (${ fullPart })`);
        lines.push('-------------------------------------------------------------------------------------------------');
        lines.push('');
        lines.push('-------------------------------------------------------------------------------------------------');
        lines.push('{{ 'front.mtg.form.results.legal.download.generatedat'|trans }}' + generatedAt);
        lines.push('-------------------------------------------------------------------------------------------------');
        lines.push('');

        for (const zoneLabel of zoneOrder) {
            const z = zones[zoneLabel];
            if (!z || !Array.isArray(z.cards) || z.cards.length === 0) continue;

            const zoneCardCount = z.cards.reduce((sum, c) => sum + (Number.isFinite(c.copies) ? c.copies : 0), 0);
            if (zoneCardCount <= 0) continue;

            lines.push('');
            lines.push(`${ zoneLabel } (${ zoneCardCount })`);

            for (const c of z.cards) {
                lines.push(`[___] ${ c.copies } ${ c.name }`);
            }
        }

        return lines.join('\n').trim() + '\n';
    };

    /**
     * @param {string} filename
     * @param {string} mime
     * @param {string} content
     */
    const downloadBlobText = (filename, mime, content) => {
        const blob = new Blob([content], { type: mime });
        const url = URL.createObjectURL(blob);

        const a = document.createElement('a');
        a.href = url;
        a.download = filename;
        a.rel = 'noopener';

        document.body.appendChild(a);
        a.click();
        a.remove();

        URL.revokeObjectURL(url);
    };

    /**
     * One-column CSV (each line becomes a row).
     *
     * @param {string} text
     * @returns {string}
     */
    const textToOneColumnCsv = (text) => {
        const normalized = String(text ?? '').replace(/\r\n/g, '\n').replace(/\n$/, '');
        const lines = normalized.split('\n');

        const escapeCell = (cell) => {
            const s = String(cell ?? '');
            const escaped = s.replace(/"/g, '""');
            return `"${ escaped }"`;
        };

        return lines.map(line => escapeCell(line)).join('\r\n') + '\r\n';
