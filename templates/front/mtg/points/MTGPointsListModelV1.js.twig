            // Default
            if ('pointsBaseQuadruples' in unranked && unranked.pointsBaseQuadruples !== null && unranked.pointsBaseQuadruples !== '') {
                MTGPointsListModelV1UnrankedListCardPoints = unranked.pointsBaseQuadruples;
