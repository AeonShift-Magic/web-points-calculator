            modulations: [],
            breakdown: [],
            errors: [],
            budget: 0,
            remaining: 0,
            mvalue: 0.0,
            mvalues: [],
            pvalue: pvalue
        };

        // Dynamically call the decklist parsing from the appropriate announcement script
        if (
            !updates
            || updates?.updates === undefined
            || updates.updates[currentFormatChoiceValues.update] === undefined
            || updates?.updates?.[currentFormatChoiceValues.update]?.pointsList === undefined
            || updates?.updates?.[currentFormatChoiceValues.update]?.pointsList?.calculatorJsFunctionPrefix === undefined
            || !['players', 'copies', 'structure', 'commander', 'timeline', 'pvalue', 'mvalue', 'update'].every(key => key in currentFormatChoiceValues)
        ) {
            [deckList1Data, deckList2Data, deckList3Data].forEach(decklistData => decklistData?.errors?.push(MESSAGES.internalerror + ' (C0001)'));
        } else {
            calculatorJsFunctionPrefix = updates?.updates?.[currentFormatChoiceValues.update]?.pointsList?.calculatorJsFunctionPrefix;

            if (calculatorJsFunctionPrefix === null) {
                [deckList1Data, deckList2Data, deckList3Data].forEach(decklistData => decklistData?.errors?.push(MESSAGES.internalerror + ' (C0002)'));
            } else {
                if (
                    typeof calculatorJsFunctionPrefix !== 'string'
                    || typeof window[calculatorJsFunctionPrefix + 'GetPValueFromFormFields'] !== 'function'
                    || typeof window[calculatorJsFunctionPrefix + 'ParseDecklist'] !== 'function'
                ) {
                    [deckList1Data, deckList2Data, deckList3Data].forEach(decklistData => decklistData?.errors?.push(MESSAGES.internalerror + ' (C0003)'));
                } else {
                    let pvalue = window[calculatorJsFunctionPrefix + 'GetPValueFromFormFields'](updates, currentFormatChoiceValues);
                    deckList1Data = window[calculatorJsFunctionPrefix + 'ParseDecklist'](deckList1, currentFormatChoiceValues, pvalue);
                    deckList2Data = window[calculatorJsFunctionPrefix + 'ParseDecklist'](deckList2, currentFormatChoiceValues, pvalue);
                    deckList3Data = window[calculatorJsFunctionPrefix + 'ParseDecklist'](deckList3, currentFormatChoiceValues, pvalue);
                }
            }
        }

        // Rewrite decklist textareas with normalized, MTGA-inspired, zone-grouped lists (only on successful parse)
        [
            { deckListData: deckList1Data, targetDOMElement: deckList1El, successDOMElement: deckList1FixedEl },
            { deckListData: deckList2Data, targetDOMElement: deckList2El, successDOMElement: deckList2FixedEl },
            { deckListData: deckList3Data, targetDOMElement: deckList3El, successDOMElement: deckList3FixedEl }
        ].forEach(({ deckListData, targetDOMElement, successDOMElement }) => {
            if (!targetDOMElement || !successDOMElement) return;
            rewriteTextareaIfParsable(targetDOMElement, deckListData);
            if (deckListData.total > 0 && deckListData.errors.length === 0) {
                successDOMElement.classList.remove('hidden');
            } else {
                successDOMElement.classList.add('hidden');
            }
        });

        // Update the P-Value base points fields
        if (deckList1BasepointsEl && deckList2BasepointsEl && deckList3BasepointsEl) {
            deckList1BasepointsEl.textContent = `${ pvalue }`;
            deckList2BasepointsEl.textContent = `${ pvalue }`;
            deckList3BasepointsEl.textContent = `${ pvalue }`;
        }

        // Update the modulations summary
        [
            { deckListData: deckList1Data, targetDOMElement: deckList1ModulationsEl },
            { deckListData: deckList2Data, targetDOMElement: deckList2ModulationsEl },
            { deckListData: deckList3Data, targetDOMElement: deckList3ModulationsEl }
        ].forEach(({ deckListData, targetDOMElement }) => {
            if (!targetDOMElement) return;
            targetDOMElement.innerHTML = '';
            if (deckListData?.modulations?.length > 0) {
                deckListData?.modulations?.forEach(modulation => targetDOMElement.insertAdjacentHTML('beforeend', `<li>${ modulation }</li>`));
            } else {
                targetDOMElement.insertAdjacentHTML('beforeend', `<li>${ MESSAGES.none }</li>`);
            }
        });

        // Update the points breakdown
        [
            { deckListData: deckList1Data, targetDOMElement: deckList1PointsUsageEl },
            { deckListData: deckList2Data, targetDOMElement: deckList2PointsUsageEl },
            { deckListData: deckList3Data, targetDOMElement: deckList3PointsUsageEl }
        ].forEach(({ deckListData, targetDOMElement }) => {
            if (!targetDOMElement) return;
            targetDOMElement.innerHTML = '';
            if (deckListData?.breakdown?.length > 0) {
                deckListData?.breakdown?.forEach(breakdown => targetDOMElement.insertAdjacentHTML('beforeend', `<li>${ breakdown }</li>`));
            } else {
                targetDOMElement.insertAdjacentHTML('beforeend', `<li>${ MESSAGES.none }</li>`);
            }
        });

        // Update the errors summary
        [
            { deckListData: deckList1Data, targetDOMElement: deckList1ErrorsEl },
            { deckListData: deckList2Data, targetDOMElement: deckList2ErrorsEl },
            { deckListData: deckList3Data, targetDOMElement: deckList3ErrorsEl }
        ].forEach(({ deckListData, targetDOMElement }) => {
            if (!targetDOMElement) return;
            targetDOMElement.innerHTML = '';
            if (deckListData?.errors?.length > 0) {
                deckListData?.errors?.forEach(error => targetDOMElement.insertAdjacentHTML('beforeend', `<li>${ error }</li>`));
            } else {
                targetDOMElement.insertAdjacentHTML('beforeend', `<li>${ MESSAGES.none }</li>`);
            }
        });

        // Update the budget and remaining points
        [
            { deckListData: deckList1Data, targetDOMElement: deckList1BudgetPointsEl },
            { deckListData: deckList2Data, targetDOMElement: deckList2BudgetPointsEl },
            { deckListData: deckList3Data, targetDOMElement: deckList3BudgetPointsEl }
        ].forEach(({ deckListData, targetDOMElement }) => {
            if (!targetDOMElement) return;
            targetDOMElement.innerHTML = '';
            targetDOMElement.insertAdjacentHTML('beforeend', `${ deckListData?.budget } 🧺`);
        });

        [
            { deckListData: deckList1Data, targetDOMElement: deckList1RemainingPointsEl },
            { deckListData: deckList2Data, targetDOMElement: deckList2RemainingPointsEl },
            { deckListData: deckList3Data, targetDOMElement: deckList3RemainingPointsEl }
        ].forEach(({ deckListData, targetDOMElement }) => {
            if (!targetDOMElement) return;
            targetDOMElement.innerHTML = '';
            if (deckListData?.remaining === 'N/A') {
                targetDOMElement.insertAdjacentHTML('beforeend', `<span class="gray-text">N/A</span>`);
            } else if (deckListData?.remaining > 0) {
                targetDOMElement.insertAdjacentHTML('beforeend', `<span class="green-text">${ deckListData?.remaining } <span class="icon-ok"></span></span>`);
            } else if (!Number.isFinite(deckListData?.remaining)) {
                targetDOMElement.insertAdjacentHTML('beforeend', `<span class="red-text">?<span class="icon-cancel"></span></span>`);
            } else {
                targetDOMElement.insertAdjacentHTML('beforeend', `<span class="red-text">0 (${ getExceedingLabel() } ${ Math.abs(deckListData?.remaining) })<span class="icon-cancel"></span></span>`);
            }
        });

        // Update the M-values found
        [
            { deckListData: deckList1Data, targetDOMElement: deckList1MvaluesEl },
            { deckListData: deckList2Data, targetDOMElement: deckList2MvaluesEl },
            { deckListData: deckList3Data, targetDOMElement: deckList3MvaluesEl }
        ].forEach(({ deckListData, targetDOMElement }) => {
            if (!targetDOMElement) return;
            targetDOMElement.innerHTML = '';
            if (Array.isArray(deckListData.mvalues) && deckListData.mvalues.length > 0) {
                deckListData?.mvalues?.forEach(breakdown => targetDOMElement.insertAdjacentHTML('beforeend', `<li>${ breakdown }</li>`));
            }
        });

        // Update the total M-value found span
        [
            { deckListData: deckList1Data, targetDOMElement: deckList1MvalueEl },
            { deckListData: deckList2Data, targetDOMElement: deckList2MvalueEl },
            { deckListData: deckList3Data, targetDOMElement: deckList3MvalueEl }
        ].forEach(({ deckListData, targetDOMElement }) => {
            if (!targetDOMElement) return;
            targetDOMElement.innerHTML = '';
            if (typeof deckListData.mvalue === 'number' && deckListData.mvalue > 0) {
                targetDOMElement.insertAdjacentHTML('beforeend', `${ Math.round(deckListData?.mvalue * 100) / 100 }`);
            }
        });

        // Update the cards found + total
        [
            { deckListData: deckList1Data, targetListDOMElement: deckList1CardsEl, targetTotalDOMElement: deckList1TotalEl },
            { deckListData: deckList2Data, targetListDOMElement: deckList2CardsEl, targetTotalDOMElement: deckList2TotalEl },
            { deckListData: deckList3Data, targetListDOMElement: deckList3CardsEl, targetTotalDOMElement: deckList3TotalEl }
        ].forEach(({ deckListData, targetListDOMElement, targetTotalDOMElement }) => {
            if (!targetListDOMElement) return;
            if (!targetTotalDOMElement) return;

            targetListDOMElement.innerHTML = '';
            targetTotalDOMElement.innerHTML = '';
            const zones = ['commandzone', 'companions', 'maindeck', 'sideboard', 'attractions', 'stickers', 'contraptions'];
            // This doesn't need i18n
            const zonesAsText = {
                commandzone: 'Command Zone',
                companions: 'Companions',
                maindeck: 'Main Deck',
                sideboard: 'Sideboard',
                attractions: 'Attractions',
                stickers: 'Sticker Packs',
                contraptions: 'Contraptions'
            };
            let total = 0;

            for (const zone of zones) {
                const cards = deckListData?.[zone];

                if (Array.isArray(cards) && cards.length > 0) {
                    targetListDOMElement.insertAdjacentHTML(
                        'beforeend',
                        `<li class="decklist-zone"><strong class="gray-text">&darr; ${ zonesAsText[zone] }</strong></li>`
                    );
                    for (const card of cards) {
                        if (card?.status !== 'unknown') {
                            ++total;
                            const imageUrl = (typeof card.imageurl === 'string' && card.imageurl)
                                ? card.imageurl
                                : unknownImageUrl;
                            targetListDOMElement.insertAdjacentHTML(
                                'beforeend',
                                `<li><a href="https://scryfall.com/search?q=${ encodeURIComponent(card.name) }" data-imageurl="${ escapeHtmlAttr(imageUrl) }" title="Scryfall Search" target="_blank"><span class="icon-search"></span> ${ card.name }</a> <span class="help-text">(x${ card.copies })</span></li>`
                            );
                        }
                    }
                }
            }

            targetListDOMElement.insertAdjacentHTML(
                'beforeend',
                `<li class="decklist-zone"><strong class="gray-text">${ MESSAGES.total } ${ total }</strong></li>`
            );

            targetTotalDOMElement.insertAdjacentHTML('beforeend', ` (${ total })`);
        });

        // Finally, depending on errors or not, show the correct div summary
        [
            { deckListData: deckList1Data, targetDOMElementLegal: deckList1LegalEl, targetDOMElementIllegal: deckList1IllegalEl, targetDOMElementErrors: deckList1ErrorsEl, targetDOMElementStart: deckList1StartEl, targetDOMTextarea: deckList1El },
            { deckListData: deckList2Data, targetDOMElementLegal: deckList2LegalEl, targetDOMElementIllegal: deckList2IllegalEl, targetDOMElementErrors: deckList2ErrorsEl, targetDOMElementStart: deckList2StartEl, targetDOMTextarea: deckList2El },
            { deckListData: deckList3Data, targetDOMElementLegal: deckList3LegalEl, targetDOMElementIllegal: deckList3IllegalEl, targetDOMElementErrors: deckList3ErrorsEl, targetDOMElementStart: deckList3StartEl, targetDOMTextarea: deckList3El }
        ].forEach(({ deckListData, targetDOMElementLegal, targetDOMElementIllegal, targetDOMElementErrors, targetDOMElementStart, targetDOMTextarea }) => {
            if (!deckListData || !targetDOMElementLegal || !targetDOMElementIllegal || !targetDOMElementErrors || !targetDOMElementStart || !targetDOMTextarea) return;

            if (targetDOMTextarea?.value.trim().length !== 0) {
                if (deckListData?.errors.length > 0) {
                    targetDOMElementLegal.classList.add('hidden');
                    targetDOMElementIllegal.classList.remove('hidden');
                    targetDOMElementErrors.classList.remove('hidden');
                    targetDOMElementStart.classList.add('hidden');
                } else {
                    targetDOMElementLegal.classList.remove('hidden');
                    targetDOMElementIllegal.classList.add('hidden');
                    targetDOMElementErrors.classList.add('hidden');
                    targetDOMElementStart.classList.add('hidden');
                }
            } else {
                targetDOMElementLegal.classList.add('hidden');
                targetDOMElementIllegal.classList.add('hidden');
                targetDOMElementErrors.classList.add('hidden');
                targetDOMElementStart.classList.remove('hidden');
            }
        });

        // Expose latest decklist structures for other interactions (e.g., "add to deck" links)
        CURRENT_DECKLIST_DATA[1] = deckList1Data;
        CURRENT_DECKLIST_DATA[2] = deckList2Data;
        CURRENT_DECKLIST_DATA[3] = deckList3Data;

        // Allow other scripts to plug in without tight coupling
        root.dispatchEvent(new CustomEvent('aeonshift:points-calculator:update', { detail: calculationInput }));
    }

    /**
     * Shared handler: add the card to textarea + recalc.
     *
     * @param {HTMLInputElement|null} nameEl
     * @param {HTMLSelectElement|null} zoneEl
     * @param {HTMLInputElement|null} copiesEl
     * @param {integer|null} id
     */
    const handleDecklistAdd = (nameEl, zoneEl, copiesEl, id) => {
        // Also: return if the name, zone, or copies are not filled.
        if (!nameEl || nameEl.value === '' || !zoneEl || zoneEl.value === '' || !copiesEl || copiesEl.value === '' || !id) return;

        const intId = Number(id ?? 0);
        const name = String(nameEl.value ?? '').trim();
        const zoneKey = String(zoneEl.value ?? '').trim();
        const copies = Number(copiesEl.value ?? 1);

        addCardToDeckStructure(intId, zoneKey, name, copies);

        // Force-reformatting the list using the shared formatter
        const textarea = intId === 1 ? deckList1El : intId === 2 ? deckList2El : deckList3El;
        const deckData = CURRENT_DECKLIST_DATA[intId];
        const rewriteFn = window.AeonShiftCalculator && window.AeonShiftCalculator.rewriteTextareaIfParsable;
        if (typeof rewriteFn === 'function' && textarea && deckData) {
            rewriteFn(textarea, deckData, true);
        }

        // Optional: clear and refocus
        nameEl.value = '';
        nameEl.focus();

        updatePointsResultsAndSummaries();

        // Success feedback
        showFlash();
    };

    /**
     * Make both clicking "Add" and submitting the form behave the same.
     */
    const bindDecklistAdd = (addEl, formEl, nameEl, zoneEl, copiesEl, id) => {
        if (addEl) {
            addEl.addEventListener('click', () => {
                handleDecklistAdd(nameEl, zoneEl, copiesEl, id);
            });
        }

        if (formEl) {
            formEl.addEventListener('submit', (e) => {
                e.preventDefault();
                handleDecklistAdd(nameEl, zoneEl, copiesEl, id);
            });
        }
    };

    bindDecklistAdd(deckList1AddEl, deckList1AddFormEl, deckList1NameEl, deckList1CardZoneEl, deckList1CopiesEl, 1);
    bindDecklistAdd(deckList2AddEl, deckList2AddFormEl, deckList2NameEl, deckList2CardZoneEl, deckList2CopiesEl, 2);
    bindDecklistAdd(deckList3AddEl, deckList3AddFormEl, deckList3NameEl, deckList3CardZoneEl, deckList3CopiesEl, 3);

    /**
     * Throttle: ensures the function runs at most once per `waitMs` (leading + trailing).
     *
     * @param {Function} fn
     * @param {number} waitMs
     */
    const throttle = (fn, waitMs) => {
        let lastRunAt = 0;
        let timeoutId = null;

        return () => {
            const now = Date.now();
            const remaining = waitMs - (now - lastRunAt);

            if (remaining <= 0) {
                if (timeoutId !== null) {
                    clearTimeout(timeoutId);
                    timeoutId = null;
                }
                lastRunAt = now;
                fn();
                return;
            }

            if (timeoutId !== null) {
                return; // already scheduled
            }

            timeoutId = window.setTimeout(() => {
                timeoutId = null;
                lastRunAt = Date.now();
                fn();
                showFlash();
            }, remaining);
        };
    };

    // Static binding to updatePointsResultsAndSummaries() to avoid recreating the function on every event
    const throttledUpdatePointsResultsAndSummaries = throttle(updatePointsResultsAndSummaries, 400);

    /**
     * Show a transient success flash for ~1s.
     * @param {string} [message='Success']
     */
    const showFlash = (message = '&#10004; {{ 'global.savesuccess.text'|trans|raw }}') => {
        const el = document.createElement('div');
        el.className = 'aeonshift-flash';
        el.innerHTML = String(message);
        document.body.appendChild(el);
        window.setTimeout(() => {
            try { el.remove(); } catch (_) {}
        }, 1400);
    };

    /**
     * Click handling for:
     * - links with data-format-switch: apply matching preset by slug
     * - links with data-quiz-target: optional form value change, optional multistep toggle, then scroll
     * Use capture so it still works even if something stops propagation on inner nodes
     *
     * @param {Event} e
     */
    document.addEventListener('click', (e) => {
        const target = e.target;
        if (!(target instanceof Element)) {
            return;
        }

        // Handle "Add to deck" actions coming from ranked cards or other lists
        const addToDeckLink = target.closest('a[data-addtodeck]');
        if (addToDeckLink) {
            e.preventDefault();
            const deckIndex = Number(addToDeckLink.getAttribute('data-addtodeck'));
            const zone = String(addToDeckLink.getAttribute('data-zone') || 'maindeck').trim();
            const cardName = String(addToDeckLink.getAttribute('data-card') || '').trim();

            if ((deckIndex === 1 || deckIndex === 2 || deckIndex === 3) && cardName) {
                // Update in-memory structure
                addCardToDeckStructure(deckIndex, zone, cardName, 1);

                // Force-reformatting the list using the shared formatter
                const textarea = deckIndex === 1 ? deckList1El : deckIndex === 2 ? deckList2El : deckList3El;
                const deckData = CURRENT_DECKLIST_DATA[deckIndex];
                const rewriteFn = window.AeonShiftCalculator && window.AeonShiftCalculator.rewriteTextareaIfParsable;
                if (typeof rewriteFn === 'function' && textarea && deckData) {
                    rewriteFn(textarea, deckData, true);
                }

                // Success feedback
                showFlash();

                // Recalculate summaries based on the new deck contents
                updatePointsResultsAndSummaries();
            }
            return;
        }

        const downloadLink = target.closest('[data-class="decklist-download-link"]');
        if (downloadLink) {
            e.preventDefault();
            const deckTargetId = downloadLink.getAttribute('data-target');
            openDownloadModal(deckTargetId);
            return;
        }

        const link = target.closest('a[data-format-switch], a[data-quiz-target]');
        if (!link) {
            return;
        }

        const formatSwitch = link.getAttribute('data-format-switch');
        if (formatSwitch && presetBySlug[formatSwitch]) {
            e.preventDefault();
            const preset = presetBySlug[formatSwitch];

            setRadio('players', preset.values.players);
            setRadio('copies', preset.values.copies);
            setRadio('structure', preset.values.structure);
            setRadio('commander', preset.values.commander);
            setRadio('timeline', preset.values.timeline);

            updateFormatNames();

            if (calculatorEl) {
                calculatorEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        }

        const quizTarget = link.getAttribute('data-quiz-target') || '';
        if (quizTarget) {
            // Prevent default navigation if it's an anchor link (we handle scrolling ourselves)
            e.preventDefault();

            const formChangeName = link.getAttribute('data-form-change');
            const formValue = link.getAttribute('data-form-value');

            if (formChangeName && formValue !== null) {
                const fields = fieldsByName[formChangeName] ?? [];
                if (fields.length > 0) {
                    for (const field of fields) {
                        const tag = field.tagName.toLowerCase();
                        const type = (field.getAttribute('type') || '').toLowerCase();

                        if (tag === 'input' && type === 'radio') {
                            field.checked = field.value === formValue;
                            if (field.checked && formChangeName in checkedByGroup) {
                                checkedByGroup[formChangeName] = field;
                            }
                            continue;
                        }

                        if (tag === 'input' && type === 'checkbox') {
                            field.checked = !(formValue === '0' || formValue === 'false' || formValue === 'off' || formValue === '');
                            continue;
                        }

                        if ('value' in field) {
                            field.value = formValue;
                        }
                    }

                    // Trigger existing listeners so format names etc. refresh
                    const checkedRadio = (checkedByGroup[formChangeName] instanceof Element) ? checkedByGroup[formChangeName] : null;
                    const eventTarget = checkedRadio || fields[0];
                    eventTarget.dispatchEvent(new Event('input', { bubbles: true }));
                    eventTarget.dispatchEvent(new Event('change', { bubbles: true }));
                }
            }

            if (quizTarget.includes('quiz-question')) {
                for (const el of multistepContainersEls) {
                    el.classList.remove('multistep-form-part-container-visible');
                }
                const targetEl = quizQuestionById[quizTarget];
                if (targetEl) {
                    targetEl.classList.add('multistep-form-part-container-visible');
                }
            }

            if (quizTarget === 'calculator') {
                if (calculatorEl) {
                    calculatorEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            } else if (quizTarget === 'quiz-question-1') {
                if (quizEl) {
                    quizEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            }
        }
    }, true);

    /**
     * Fill the ranked cards table body (#ranked-cards-container) with cards from the current update pointsList.
     *
     * Rows contain:
     * - Card key
     * - Calculated points (via `${prefix}CalculatePointsForCardInPointsList`)
     * - Mana Value
     * - CI icons/spans
     */
    const renderRankedCardsContainer = () => {
        if (!(rankedCardsTbodyEl instanceof HTMLTableSectionElement)) {
            return;
        }

        const currentFormatChoiceValues = getCurrentFormatChoiceValues();

        /** @type {*} */
        const pointsList = updates?.updates?.[currentFormatChoiceValues.update]?.pointsList ?? null;

        /** @type {*} */
        const ranked = pointsList?.ranked ?? null;

        rankedCardsTbodyEl.innerHTML = '';

        if (typeof ranked !== 'object' || ranked.length === 0) {
            return;
        }

        const calculatorJsFunctionPrefix =
            updates?.updates?.[currentFormatChoiceValues.update]?.pointsList?.calculatorJsFunctionPrefix ?? null;

        if (typeof calculatorJsFunctionPrefix !== 'string' || calculatorJsFunctionPrefix.trim() === '') {
            return;
        }

        const calculatePointsForCardInPointsListFn =
            window[calculatorJsFunctionPrefix + 'CalculatePointsForCardInPointsList'];

        if (typeof calculatePointsForCardInPointsListFn !== 'function') {
            return;
        }

        const documentFragment = document.createDocumentFragment();

        for (const [key, value] of Object.entries(ranked)) {
            const cardData = value ?? null;

            const cardname = String(key).trim();
            if (!cardname) continue;

            const cardPoints = calculatePointsForCardInPointsListFn(
                cardname,
                pointsList,
                currentFormatChoiceValues,
                'maindeck'
            );

            if (cardPoints.status === 'found') {
                const tr = document.createElement('tr');
                const tdKey = document.createElement('td');
                const cardImageUrl = (
                    cardPoints?.status === 'unknown'
                    || typeof cardPoints.imageurl !== 'string'
                    || cardPoints.imageurl === ''
                )
                    ? unknownImageUrl
                    : cardPoints.imageurl;

                // Card Name (+ image and search link)
                tdKey.innerHTML =
                    `<strong class="${ cardPoints.status }">
                         <a href="https://scryfall.com/search?q=${ encodeURIComponent(cardname) }" data-imageurl="${ escapeHtmlAttr(cardImageUrl) }" title="Scryfall Search" target="_blank">
                            <span class="icon-search"></span> ${ cardPoints?.name ?? cardname }
                        </a>
                    </strong>`
                ;
                // Add it to the main row
                tr.setAttribute('data-commander-name', cardPoints?.name ?? cardname);

                // Card ranking in points
                const tdPoints = document.createElement('td');
                tdPoints.innerHTML = `<strong class="commander-budget font-bold text-lg ${ Number(cardPoints.points) > 0 ? 'red-text' : Number(cardPoints.points) < 0 ? 'green-text' : 'gray-text' }">${ String(cardPoints?.points ?? '') }</strong>`;

                // Add to deck buttons
                const tdAddToDeck = document.createElement('td');
                tdAddToDeck.innerHTML = `
                    <a data-card="${ cardname }" data-addtodeck="1" data-zone="maindeck" class="btn btn-green text-sm addtodeck1 cursor-pointer py-0! my-0! px-1!" title="{{ 'front.mtg.choose.links.choosecommander.table.addtodeck.title'|trans|e('html_attr') }} 1"><span class="icon-plus-circled"></span> {{ 'front.mtg.choose.links.choosecommander.table.addtodeck.label'|trans|raw }} 1</a>
                    <a data-card="${ cardname }" data-addtodeck="2" data-zone="maindeck" class="btn btn-blue text-sm addtodeck2 cursor-pointer py-0! my-0! px-1!" title="{{ 'front.mtg.choose.links.choosecommander.table.addtodeck.title'|trans|e('html_attr') }} 2"><span class="icon-plus-circled"></span> {{ 'front.mtg.choose.links.choosecommander.table.addtodeck.label'|trans|raw }} 2</a>
                    <a data-card="${ cardname }" data-addtodeck="3" data-zone="maindeck" class="btn btn-yellow text-sm addtodeck3 cursor-pointer py-0! my-0! px-1!" title="{{ 'front.mtg.choose.links.choosecommander.table.addtodeck.title'|trans|e('html_attr') }} 3"><span class="icon-plus-circled"></span> {{ 'front.mtg.choose.links.choosecommander.table.addtodeck.label'|trans|raw }} 3</a>
                `;

                // CEDH Ranking on EDHRec
                const tdEDHRecRank = document.createElement('td');
                tdEDHRecRank.innerHTML = Number(cardData?.cedhrank) > 0 ? '#' + (cardData?.cedhrank ?? '') : '';

                // Mana Value
                const tdMv = document.createElement('td');
                tdMv.innerHTML = String(cardData?.mv ?? '');

                // Color Identity
                const tdCi = document.createElement('td');
                const ci = cardData?.ci;
                let rawCi = '';

                if (Array.isArray(ci) && ci.length > 0) {
                    for (const v of ci) {
                        const c = String(v ?? '').trim().toUpperCase();
                        if (!c) continue;

                        tr.setAttribute('data-color-' + c, 'true');
                        const span = document.createElement('span');
                        rawCi += c;
                        span.title = c;
                        span.className = `color-identity color-identity-${ String(c).toLowerCase() }`;
                        span.textContent = c;

                        tdCi.appendChild(span);
                    }
                }

                tr.setAttribute('data-color-identity', String(rawCi).toUpperCase());

                // Maximum Timeline
                tr.setAttribute('data-maximum-timeline', cardData?.timeline);

                tr.appendChild(tdKey);
                tr.appendChild(tdPoints);
                tr.appendChild(tdAddToDeck);
                tr.appendChild(tdEDHRecRank);
                tr.appendChild(tdMv);
                tr.appendChild(tdCi);

                documentFragment.appendChild(tr);
            }
        }

        rankedCardsTbodyEl.appendChild(documentFragment);
    };

    /**
     * Update the format names and points results when any of the format choice inputs change.
     *
     * @param {Event} e
     */
    const onControlChange = (e) => {
        const target = e.target;
        if (!(target instanceof Element)) {
            return;
        }

        if (!target.hasAttribute('data-update-format')) {
            return;
        }

        if (target.tagName.toLowerCase() === 'textarea') {
            throttledUpdatePointsResultsAndSummaries();
            return;
        }

        if (target.matches('input[type="radio"][name]')) {
            const name = target.getAttribute('name');
            if (name && name in checkedByGroup) {
                checkedByGroup[name] = target;
            }
        }

        if (target.matches('input, select')) {
            updateFormatNames();
            throttledUpdatePointsResultsAndSummaries();
            renderRankedCardsContainer();

            if (target === updateSelectEl) {
                recalculateChooseCommanderTableBudgets();
            }
        }
    };
    // Use capture so it still works even if something stops propagation on inner nodes
    root.addEventListener('change', onControlChange, true);
    root.addEventListener('input', onControlChange, true);

    // Shortcut: predefined slugs force a predefined state (ignore query params)
    const forcedPreset = presetBySlug[slug];
    if (forcedPreset) {
        setRadio('players', forcedPreset.values.players);
        setRadio('copies', forcedPreset.values.copies);
        setRadio('structure', forcedPreset.values.structure);
        setRadio('commander', forcedPreset.values.commander);
        setRadio('timeline', forcedPreset.values.timeline);
        updateFormatNames();
        return;
    }

    // Get URL query parameters
    const params = new URLSearchParams(window.location.search);

    for (const el of formFieldsEls) {
        const tag = el.tagName.toLowerCase();
        const type = (el.getAttribute('type') || '').toLowerCase();

        const key = el.getAttribute('name') || el.getAttribute('id');
        if (!key || !ALLOWED_FORM_KEYS.has(key) || !params.has(key)) {
            continue;
        }

        const raw = params.get(key);
        if (raw === null) {
            continue;
        }

        if (tag === 'input' && type === 'radio') {
            setRadio(key, raw);
            continue;
        }

        if (tag === 'input' && type === 'checkbox') {
            el.checked = !(raw === '0' || raw === 'false' || raw === 'off' || raw === '');
            continue;
        }

        if (tag === 'textarea') {
            setValueById(key, raw);
            continue;
        }

        if (tag === 'select' || tag === 'input') {
            el.value = raw;
        }
    }

    updateFormatNames();

    // Initialize static bindings once (fast, no heavy work)
    CHOOSE_COMMANDER_TABLE.init();

    window.requestAnimationFrame(() => {
        updatePointsResultsAndSummaries();
        renderRankedCardsContainer();

        if (CHOOSE_COMMANDER_TABLE.getTableEl()) {
            initChooseCommanderTableSorting();
            initChooseCommanderTableFiltering();
        }

        CHOOSE_CARDS_TABLE.init();
        if (CHOOSE_CARDS_TABLE.getTableEl()) {
            initChooseCardsTableSorting();
            initChooseCardsTableFiltering();
        }

        window.__chooseCommanderBudgetAbortController = new AbortController();
        recalculateChooseCommanderTableBudgets({
            signal: window.__chooseCommanderBudgetAbortController.signal
        });
    });
});
