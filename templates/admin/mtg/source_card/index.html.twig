{% extends 'admin/admin_layout.html.twig' %}

{% block title %}{{ 'admin.mtg.sourcecard.index.title'|trans }}{% endblock %}

{% block body %}
    <div class="container mx-auto px-4 py-8">
        <div class="flex justify-between items-center mb-6">
            <h1>{{ 'admin.mtg.sourcecard.index.heading'|trans }}</h1>
        </div>

        {% if source_cards|length > 0 %}
            <div class="bg-white shadow-md rounded-lg overflow-hidden">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                {{ 'admin.mtg.sourcecard.index.id'|trans }}
                            </th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                {{ 'admin.mtg.sourcecard.index.name'|trans }}
                            </th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                {{ 'admin.mtg.sourcecard.index.set'|trans }}
                            </th>
                            <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
                                {{ 'admin.mtg.sourcecard.index.actions'|trans }}
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for source_card in source_cards %}
                            <tr>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                    {{ source_card.id }}
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                                    {{ source_card.name }}
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                    {{ source_card.setCode }}
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                    <a href="{{ path('admin_mtg_source_card_show', {'id': source_card.id}) }}" class="text-blue-600 hover:text-blue-900 mr-3">
                                        {{ 'admin.mtg.sourcecard.index.show'|trans }}
                                    </a>
                                    <form method="post" action="{{ path('admin_mtg_source_card_delete', {'id': source_card.id}) }}"
                                          onsubmit="return confirm('{{ 'admin.mtg.sourcecard.index.confirm_delete'|trans }}');"
                                          class="inline-block">
                                        <input type="hidden" name="_method" value="DELETE">
                                        <button type="submit" class="text-red-600 hover:text-red-900">
                                            {{ 'admin.mtg.sourcecard.index.delete'|trans }}
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            <div class="mt-6">
                {{ knp_pagination_render(source_cards) }}
            </div>
        {% else %}
            <div class="bg-white shadow-md rounded-lg p-6 text-center">
                <p class="text-gray-500">{{ 'admin.mtg.sourcecard.index.no_results'|trans }}</p>
            </div>
        {% endif %}
    </div>
{% endblock %}
