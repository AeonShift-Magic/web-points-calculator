    const deckList2BudgetPointsEl = root.querySelector('#decklist2-budget-points');
    const deckList3BudgetPointsEl = root.querySelector('#decklist3-budget-points');
    const deckList1RemainingPointsEl = root.querySelector('#decklist1-remaining-points');
    const deckList2RemainingPointsEl = root.querySelector('#decklist2-remaining-points');
    const deckList3RemainingPointsEl = root.querySelector('#decklist3-remaining-points');
    const deckList1LegalEl = root.querySelector('#decklist1-legal');
    const deckList2LegalEl = root.querySelector('#decklist2-legal');
    const deckList3LegalEl = root.querySelector('#decklist3-legal');
    const deckList1IllegalEl = root.querySelector('#decklist1-illegal');
    const deckList2IllegalEl = root.querySelector('#decklist2-illegal');
    const deckList3IllegalEl = root.querySelector('#decklist3-illegal');

    /**
