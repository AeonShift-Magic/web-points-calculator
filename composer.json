{
    "name": "aeonshift/web-points-calculator",
    "description": "AeonShift Points Calculator",
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "ext-bcmath": "*",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "ext-zend-opcache": "*",
        "doctrine/dbal": "^4.4.1",
        "doctrine/doctrine-bundle": "^3.2.2",
        "doctrine/doctrine-migrations-bundle": "^3.7.0",
        "doctrine/orm": "^3.6.2",
        "friendsofsymfony/ckeditor-bundle": "^2.8.0",
        "halaxa/json-machine": "^1.2.6",
        "helios-ag/fm-elfinder-bundle": "^12.7.3",
        "karser/karser-recaptcha3-bundle": ">=0.3.0",
        "knplabs/knp-paginator-bundle": "^6.10.0",
        "liip/imagine-bundle": "^2.17.1",
        "nelmio/api-doc-bundle": "*",
        "symfony/apache-pack": ">=1.0.1",
        "symfony/asset": "7.4.*",
        "symfony/cache": "7.4.*",
        "symfony/console": "7.4.*",
        "symfony/dotenv": "7.4.*",
        "symfony/flex": "^2.10.0",
        "symfony/framework-bundle": "7.4.*",
        "symfony/google-mailer": "7.4.*",
        "symfony/html-sanitizer": "7.4.*",
        "symfony/http-client": "7.4.*",
        "symfony/intl": "7.4.*",
        "symfony/json-streamer": "7.4.*",
        "symfony/lock": "7.4.*",
        "symfony/mailer": "7.4.*",
        "symfony/messenger": "7.4.*",
        "symfony/monolog-bundle": "^4.0.1",
        "symfony/runtime": "7.4.*",
        "symfony/security-bundle": "7.4.*",
        "symfony/stimulus-bundle": "^2.32.0",
        "symfony/translation": "7.4.*",
        "symfony/twig-bundle": "7.4.*",
        "symfony/uid": "7.4.*",
        "symfony/ux-icons": "^2.32",
        "symfony/ux-live-component": "^2.32",
        "symfony/ux-turbo": "^2.32.0",
        "symfony/ux-twig-component": "^2.32",
        "symfony/validator": "7.4.*",
        "symfony/yaml": "7.4.*",
        "symfonycasts/reset-password-bundle": "^1.24.0",
        "symfonycasts/tailwind-bundle": "^0.10.1",
        "symfonycasts/verify-email-bundle": "^1.18.0",
        "twig/cache-extra": "^3.23.0",
        "twig/extra-bundle": ">=3.23.0",
        "twig/intl-extra": "^3.23.0",
        "twig/string-extra": "^3.23.0",
        "twig/twig": "^3.23.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.93.1",
        "phpstan/extension-installer": "^1.4.3",
        "phpstan/phpstan": "^2.1.38",
        "phpstan/phpstan-doctrine": "^2.0.14",
        "phpstan/phpstan-symfony": "^2.0.12",
        "phpunit/phpunit": "^12.5.9",
        "roave/security-advisories": "dev-latest",
        "symfony/browser-kit": "7.4.*",
        "symfony/css-selector": "7.4.*",
        "symfony/debug-bundle": "7.4.*",
        "symfony/maker-bundle": "^1.65.1",
        "symfony/stopwatch": "7.4.*",
        "symfony/web-profiler-bundle": "7.4.*",
        "vimeo/psalm": "^6.15.0",
        "weirdan/doctrine-psalm-plugin": "^2.10"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "phpstan/extension-installer": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd",
            "ckeditor:install --tag=4.22.1": "symfony-cmd",
            "elfinder:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": "true",
            "require": "7.4.*"
        }
    }
}
