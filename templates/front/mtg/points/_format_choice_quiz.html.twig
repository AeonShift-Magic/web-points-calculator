<div class="spaceless-row theme2 quiz-choice-row my-4" id="quiz">
    <div class="main-column no-shadow lg:pt-4 min-h-screen">

        <div class="w-full text-center flex flex-col justify-center items-center my-3">

            <div class="flex flex-col lg:flex-row w-full justify-around items-center">
                <a class="btn btn-star btn-green btn-big m-2" href="#formats" title="{{ 'front.mtg.choose.links.choose.title'|trans|striptags }}" data-turbo="false">
                    <span class="top-left"></span>
                    <span class="top-right"></span>
                    <span class="title">
                        <span class="icon-target"></span>
                        {{ 'front.mtg.choose.links.choose.text'|trans }}
                    </span>
                    <span class="bottom-left"></span>
                    <span class="bottom-right"></span>
                </a>
                <a class="btn btn-star btn-gray btn-big m-2" href="#calculator" title="{{ 'front.mtg.choose.links.gotoform.title'|trans|striptags }}" data-turbo="false">
                    <span class="top-left"></span>
                    <span class="top-right"></span>
                    <span class="title">
                        <span class="icon-chart-bar"></span>
                        {{ 'front.mtg.choose.links.gotoform.text'|trans }}
                    </span>
                    <span class="bottom-left"></span>
                    <span class="bottom-right"></span>
                </a>
                <a class="btn btn-star btn-gray btn-big m-2" href="#calculator" title="{{ 'front.mtg.choose.links.freeform.title'|trans|striptags }}" data-turbo="false">
                    <span class="top-left"></span>
                    <span class="top-right"></span>
                    <span class="title">
                        <span class="icon-cancel"></span>
                        {{ 'front.mtg.choose.links.freeform.text'|trans }}
                    </span>
                    <span class="bottom-left"></span>
                    <span class="bottom-right"></span>
                </a>
            </div>
        </div>

        <div class="w-full text-center flex flex-col justify-center items-center">
        </div>

    </div>
</div>
