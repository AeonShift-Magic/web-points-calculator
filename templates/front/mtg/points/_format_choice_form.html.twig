        {# Points list update #}
        <div class="form-split">
            <div class="flex flex-col lg:flex-row items-center justify-around text-left">
                <div class="w-full lg:w-1/3 lg:pr-6">
                    <div class="label w-full"><label for="update">{{ 'front.mtg.quiz.question8.label'|trans }}</label></div>
                    <div class="help-text w-full">{{ 'front.mtg.quiz.question8.text'|trans }}</div>
                </div>
                <div class="w-full lg:w-2/3 mt-2 lg:mt-0">
                    <div class="switch-field">
                        <select name="update" id="update" data-update-format>
                            {% if updates is defined and updates is iterable %}
                                {% for title_and_date, id in updates %}
                                    <option value="{{ id }}" {% if loop.first %}selected="selected"{% endif %}>{{ title_and_date }}</option>
                                {% else %}
                                    <option value="" disabled="disabled">{{ 'global.none.label'|trans }}</option>
                                {% endfor %}
                            {% else %}
                                <option value="" disabled="disabled">{{ 'global.none.label'|trans }}</option>>
                            {% endif %}
                        </select>
                    </div>
