<div class="spaceless-row gradient-down-theme2 relative z-40" id="card-rankings">
    <div class="main-column no-shadow py-2">
        <div class="w-full text-center flex flex-col justify-center items-center my-3">

            <div class="flex flex-col lg:flex-row w-full justify-around items-center">
                <a class="btn btn-star btn-blue btn-big m-2" href="#quiz" title="{{ 'front.mtg.choose.links.quiz.title'|trans|striptags }}" data-quiz-target="quiz-question-1" data-turbo="false">
                    <span class="top-left"></span>
                    <span class="top-right"></span>
                    <span class="title">
                        <span class="icon-question"></span>
                        {{ 'front.mtg.choose.links.quiz.text'|trans }}
                    </span>
                    <span class="bottom-left"></span>
                    <span class="bottom-right"></span>
                </a>
                <img src="{{ asset('images/aeonshift-logo-transparent-format.png') }}" alt="AeonShiftlogo" class="w-auto h-10 m-4">
                <a class="btn btn-star btn-gray btn-big m-2" href="#calculator" title="{{ 'front.mtg.choose.links.gotoform.title'|trans|striptags }}" data-turbo="false">
                    <span class="top-left"></span>
                    <span class="top-right"></span>
                    <span class="title">
                        <span class="icon-up-big"></span> {{ 'front.mtg.choose.links.gotoform.back'|trans }}
                    </span>
                    <span class="bottom-left"></span>
                    <span class="bottom-right"></span>
                </a>
            </div>

        </div>
    </div>
</div>

<div class="spaceless-row theme1 bg-row-3 quiz-choice-row relative z-10 min-h-[1200px]">
    <div class="main-column no-shadow py-2 h-[1200px] format-incentive my-8">
        <div class="w-full flex flex-col justify-around items-center p-px mb-4 lg:px-4">
            <h2>{{ 'front.mtg.choose.links.cardpoints.text'|trans }}</h2>
            <p class="blue-text text-center my-1">
                <span class="icon-info"></span> {{ 'front.mtg.choose.links.cardpoints.description'|trans }}
            </p>
            <p class="blue-text text-center my-1 pb-2">
                <span class="icon-info"></span> {{ 'front.mtg.choose.links.choosecommander.description3'|trans }}
            </p>
            <div class="w-full flex justify-center">
                <form id="choose-card-filter" class="w-full">
                    <fieldset class="flex flex-col mb-2">
                        <div class="w-full flex flex-row flex-wrap items-center mb-2">

                            <div class="inline-form-item flex-grow min-w-0 mx-2 my-1">
                                <label for="choose-card-name">{{ 'front.mtg.choose.links.choosecommander.table.nameen.label'|trans }} {{ ux_icon('flag:gb-4x3') }}</label>
                                <input
                                    type="text"
                                    title="{{ 'front.mtg.choose.links.choosecommander.table.nameen.label'|trans|e('html_attr') }}"
                                    name="choose-card-name"
                                    id="choose-card-name"
                                    value=""
                                    placeholder="{{ 'front.mtg.choose.links.choosecommander.table.nameen.placeholder'|trans }}"
                                    data-update-card-rankings
                                />
                            </div>

                            <div class="flex flex-col grow min-w-0 items-center justify-center mx-2 my-1">
                                <label class="w-full" for="choose-card-color-identity">{{ 'front.mtg.choose.links.choosecommander.table.coloridentity.label'|trans }}</label>
                                <div class="w-full flex flex-row py-2">
                                    {% for color in ['W', 'U', 'B', 'R', 'G', 'C'] %}
                                        <div class="color-picker color-picker-{{ color|lower }} color-identity-{{ color|lower }}">
                                            <label for="choose-card-color-identity-{{ color|lower }}">{{ color|lower }}</label>
                                            <input
                                                type="checkbox"
                                                name="choose-card-color-identity[]"
                                                id="choose-card-color-identity-{{ color|lower }}"
                                                data-color="data-color-{{ color|lower }}"
                                                value="{{ color }}"
                                                title="{ {{ color|lower }} }"
                                                data-update-card-rankings
                                            >
                                        </div>
                                    {% endfor %}
                                </div>
                            </div>

                        </div>
                    </fieldset>
                </form>
            </div>
            <div class="table-wrapper my-4 p-0 overflow-scroll max-h-[800px] border-solid border-gray border w-full">
                <table class="table center header-highlight-table w-full m-0 p-0 sortable-table" style="margin: 0 !important;" id="choose-cards-table">
                    <thead class="top-0" style="top: 0 !important;">
                        <tr>
                            <th title="{{ 'front.mtg.choose.links.choosecommander.table.sort.label'|trans|e('html_attr') }}" class="sortable" role="button" tabindex="0">{{ 'front.mtg.choose.links.choosecommander.table.nameen.label'|trans }} {{ ux_icon('flag:gb-4x3') }}</th>
                            <th title="{{ 'front.mtg.choose.links.choosecommander.table.sort.label'|trans|e('html_attr') }}" class="sortable" role="button" tabindex="0" style="width: 100px;">{{ 'front.mtg.choose.links.choosecommander.table.points.label'|trans }}</th>
                            <th title="{{ 'front.mtg.choose.links.choosecommander.table.addtodeck.title'|trans }}">{{ 'front.mtg.choose.links.choosecommander.table.addtodeck.title'|trans }}</th>
                            <th title="{{ 'front.mtg.choose.links.choosecommander.table.sort.label'|trans|e('html_attr') }}" class="sortable" role="button" tabindex="0" style="width: 270px;">{{ 'front.mtg.choose.links.choosecommander.table.rankingindex.cedh.label'|trans }}</th>
                            <th title="{{ 'front.mtg.choose.links.choosecommander.table.sort.label'|trans|e('html_attr') }}" class="sortable" role="button" tabindex="0" style="width: 115px;">{{ 'front.mtg.choose.links.choosecommander.table.mv.label'|trans }}</th>
                            <th title="{{ 'front.mtg.choose.links.choosecommander.table.sort.label'|trans|e('html_attr') }}" class="sortable" role="button" tabindex="0" style="width: 145px;">{{ 'front.mtg.choose.links.choosecommander.table.coloridentity.label'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody data-update-ranked-cards id="ranked-cards-container">
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
