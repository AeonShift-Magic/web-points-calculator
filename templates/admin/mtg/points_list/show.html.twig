{% extends 'admin/admin_layout.html.twig' %}

{% block title %}{{ 'admin.nav.mtg.pointslist.show.label'|trans({'name': points_list.title}) }}{% endblock %}

{% block body %}
    <h1>{{ 'admin.nav.mtg.pointslist.show.label'|trans({'name': points_list.title}) }}</h1>

    <div class="flex flex-col gap-2 lg:flex-row lg:gap-4 w-full lg:justify-center my-2">
        <a class="btn btn-gray" href="{{ url('admin_mtg_points_list_index') }}" title="{{ 'global.indexbutton.title'|trans }}">{{ 'global.indexbutton.label'|trans }}</a>
        <a class="btn btn-blue" href="{{ url('admin_mtg_points_list_export', {'id': points_list.id}) }}" title="{{ 'global.export.title'|trans }}">{{ 'global.export.label'|trans }}</a>
        <a class="btn btn-blue" href="{{ url('admin_mtg_points_list_import', {'id': points_list.id}) }}" title="{{ 'global.import.title'|trans }}">{{ 'global.import.label'|trans }}</a>
        <a class="btn btn-green" href="{{ url('admin_mtg_points_list_edit', {'id': points_list.id}) }}" title="{{ 'global.editbutton.title'|trans }}">{{ 'global.editbutton.label'|trans }}</a>

        <div>
            {{ include('admin/mtg/points_list/_delete_form.html.twig') }}
        </div>
    </div>

    <div class="table-wrapper">
        <table class="table center header-highlight-table">
            <tbody>
                <tr>
                    <th class="w-1/4">{{ 'global.id.label'|trans }}</th>
                    <td>{{ points_list.id }}</td>
                </tr>
                <tr>
                    <th>{{ 'admin.form.mtg.pointslist.create.title.label'|trans }}</th>
                    <td>{{ points_list.title }}</td>
                </tr>
                <tr>
                    <th>{{ 'admin.form.mtg.pointslist.create.rulesmodel.label'|trans }}</th>
                    <td>
                        {{ points_list.rulesModelName }} <em>({{ points_list.rulesModel }})</em>
                    </td>
                </tr>
                <tr>
                    <th>{{ 'admin.form.mtg.pointslist.create.relatedupdates.label'|trans }}</th>
                    <td>
                        {% for mtg_update in points_list.MTGUpdates %}
                            <a href="{{ url('admin_mtg_update_show', {'id': mtg_update.id}) }}" title="{{ 'admin.nav.mtg.update.show.title'|trans({'name': mtg_update.titleEn}) }}">{{ mtg_update.titleEn }}</a>
                            {% if not loop.last %}<br>{% endif %}
                        {% else %}
                            {{ 'global.none.label'|trans }}
                        {% endfor %}
                    </td>
                </tr>
                <tr>
                    <th>{{ 'admin.form.mtg.pointslist.create.filename.label'|trans }}</th>
                    <td>{{ points_list.filename }}</td>
                </tr>
                <tr>
                    <th>{{ 'admin.form.mtg.pointslist.create.lastuploadedat.label'|trans }}</th>
                    <td>{{ points_list.lastUploadedAt|date('Y-m-d H:i') }}</td>
                </tr>
                <tr>
                    <th>{{ 'admin.form.mtg.pointslist.import.pvalues.text'|trans }}</th>
                    <td class="text-center">
                        <table class="table center">
                            <thead>
                                <tr>
                                    <th colspan="2">{{ 'admin.form.mtg.pointslist.import.pvalues.header.standardplay.text'|trans }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>{{ 'admin.form.mtg.pointslist.import.pvalues.standardplay.basesingleton.text'|trans }}</td>
                                    <td>{{ points_list.pValueBaseSingletonStandardPlay }}</td>
                                </tr>
                                <tr>
                                    <td>{{ 'admin.form.mtg.pointslist.import.pvalues.standardplay.basequadruples.text'|trans }}</td>
                                    <td>{{ points_list.pValueBaseQuadruplesStandardPlay }}</td>
                                </tr>
                                <tr>
                                    <td>{{ 'admin.form.mtg.pointslist.import.pvalues.standardplay.duelcommander.text'|trans }}</td>
                                    <td>{{ points_list.pValueDuelCommanderStandardPlay }}</td>
                                </tr>
                                <tr>
                                    <td>{{ 'admin.form.mtg.pointslist.import.pvalues.standardplay.commander.text'|trans }}</td>
                                    <td>{{ points_list.pValueCommanderStandardPlay }}</td>
                                </tr>
                                <tr>
                                    <td>{{ 'admin.form.mtg.pointslist.import.pvalues.standardplay.highlander.text'|trans }}</td>
                                    <td>{{ points_list.pValueHighlanderStandardPlay }}</td>
                                </tr>
                                <tr>
                                    <td>{{ 'admin.form.mtg.pointslist.import.pvalues.standardplay.modern.text'|trans }}</td>
                                    <td>{{ points_list.pValueModernStandardPlay }}</td>
                                </tr>
                                <tr>
                                    <td>{{ 'admin.form.mtg.pointslist.import.pvalues.standardplay.pioneer.text'|trans }}</td>
                                    <td>{{ points_list.pValuePioneerStandardPlay }}</td>
                                </tr>
                                <tr>
                                    <td>{{ 'admin.form.mtg.pointslist.import.pvalues.standardplay.standard.text'|trans }}</td>
                                    <td>{{ points_list.pValueStandardStandardPlay }}</td>
                                </tr>
                            </tbody>
                        </table>
                        <br>
                        <table class="table center">
                            <thead>
                                <tr>
                                    <th colspan="2">{{ 'admin.form.mtg.pointslist.import.pvalues.header.liteplay.text'|trans }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>{{ 'admin.form.mtg.pointslist.import.pvalues.liteplay.basesingleton.text'|trans }}</td>
                                    <td>{{ points_list.pValueBaseSingletonLitePlay }}</td>
                                </tr>
                                <tr>
                                    <td>{{ 'admin.form.mtg.pointslist.import.pvalues.liteplay.basequadruples.text'|trans }}</td>
                                    <td>{{ points_list.pValueBaseQuadruplesLitePlay }}</td>
                                </tr>
                                <tr>
                                    <td>{{ 'admin.form.mtg.pointslist.import.pvalues.liteplay.duelcommander.text'|trans }}</td>
                                    <td>{{ points_list.pValueDuelCommanderLitePlay }}</td>
                                </tr>
                                <tr>
                                    <td>{{ 'admin.form.mtg.pointslist.import.pvalues.liteplay.commander.text'|trans }}</td>
                                    <td>{{ points_list.pValueCommanderLitePlay }}</td>
                                </tr>
                                <tr>
                                    <td>{{ 'admin.form.mtg.pointslist.import.pvalues.liteplay.highlander.text'|trans }}</td>
                                    <td>{{ points_list.pValueHighlanderLitePlay }}</td>
                                </tr>
                                <tr>
                                    <td>{{ 'admin.form.mtg.pointslist.import.pvalues.liteplay.modern.text'|trans }}</td>
                                    <td>{{ points_list.pValueModernLitePlay }}</td>
                                </tr>
                                <tr>
                                    <td>{{ 'admin.form.mtg.pointslist.import.pvalues.liteplay.pioneer.text'|trans }}</td>
                                    <td>{{ points_list.pValuePioneerLitePlay }}</td>
                                </tr>
                                <tr>
                                    <td>{{ 'admin.form.mtg.pointslist.import.pvalues.liteplay.standard.text'|trans }}</td>
                                    <td>{{ points_list.pValueStandardLitePlay }}</td>
                                </tr>
                            </tbody>
                        </table>
                        <br>
                        <table class="table center">
                            <thead>
                                <tr>
                                    <th colspan="2">{{ 'admin.form.mtg.pointslist.import.pvalues.header.powerplay.text'|trans }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>{{ 'admin.form.mtg.pointslist.import.pvalues.powerplay.basesingleton.text'|trans }}</td>
                                    <td>{{ points_list.pValueBaseSingletonPowerPlay }}</td>
                                </tr>
                                <tr>
                                    <td>{{ 'admin.form.mtg.pointslist.import.pvalues.powerplay.basequadruples.text'|trans }}</td>
                                    <td>{{ points_list.pValueBaseQuadruplesPowerPlay }}</td>
                                </tr>
                                <tr>
                                    <td>{{ 'admin.form.mtg.pointslist.import.pvalues.powerplay.duelcommander.text'|trans }}</td>
                                    <td>{{ points_list.pValueDuelCommanderPowerPlay }}</td>
                                </tr>
                                <tr>
                                    <td>{{ 'admin.form.mtg.pointslist.import.pvalues.powerplay.commander.text'|trans }}</td>
                                    <td>{{ points_list.pValueCommanderPowerPlay }}</td>
                                </tr>
                                <tr>
                                    <td>{{ 'admin.form.mtg.pointslist.import.pvalues.powerplay.highlander.text'|trans }}</td>
                                    <td>{{ points_list.pValueHighlanderPowerPlay }}</td>
                                </tr>
                                <tr>
                                    <td>{{ 'admin.form.mtg.pointslist.import.pvalues.powerplay.modern.text'|trans }}</td>
                                    <td>{{ points_list.pValueModernPowerPlay }}</td>
                                </tr>
                                <tr>
                                    <td>{{ 'admin.form.mtg.pointslist.import.pvalues.powerplay.pioneer.text'|trans }}</td>
                                    <td>{{ points_list.pValuePioneerPowerPlay }}</td>
                                </tr>
                                <tr>
                                    <td>{{ 'admin.form.mtg.pointslist.import.pvalues.powerplay.standard.text'|trans }}</td>
                                    <td>{{ points_list.pValueStandardPowerPlay }}</td>
                                </tr>
                            </tbody>
                        </table>
                    </td>
                </tr>
                <tr>
                    <th>{{ 'admin.form.mtg.pointslist.create.uploadnbcards.label'|trans }}</th>
                    <td>{{ points_list.numberOfUploadedCards }}</td>
                </tr>
                <tr>
                    <th>{{ 'admin.form.mtg.pointslist.create.currentnbcards.label'|trans }}</th>
                    <td>
                        <p class="py-1">
                            {{ points_list.MTGPointListCards|length }}
                        </p>
                        {% if points_list.MTGPointListCards|length > 0 %}
                            <table class="table center header-highlight-table mt-4">
                                <thead>
                                    <tr>
                                        <th>{{ 'admin.form.mtg.pointslistcard.create.nameen.label'|trans }}</th>
                                        <th colspan="8w">{{ 'admin.mtg.pointslistcard.points.label'|trans }}</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for points_list_card in points_list.MTGPointListCards %}
                                        <tr>
                                            <td>
                                                <a href="{{ url('admin_mtg_points_list_card_show', {'id': points_list_card.id}) }}" title="">{{ points_list_card.nameEN }}</a>
                                            </td>
                                            {# Points (Base Singleton/Quadruples - DC/S - Commander/S - 2HG/S - Highlander - Modern - Pioneer - Standard) #}
                                            <td>
                                                <span class="text-blue-300">
                                                    {% if points_list_card.pointsBaseSingleton > 0 %}<strong>{% endif %}{{ points_list_card.pointsBaseSingleton }}{% if points_list_card.pointsBaseSingleton > 0 %}</strong>{% endif %}
                                                    /
                                                    {% if points_list_card.pointsBaseQuadruples > 0 %}<strong>{% endif %}{{ points_list_card.pointsBaseQuadruples }}{% if points_list_card.pointsBaseQuadruples > 0 %}</strong>{% endif %}
                                                </span>
                                            </td>
                                            <td>
                                                <span class="text-orange-300">
                                                    {% if points_list_card.pointsDuelCommander > 0 %}<strong>{% endif %}{{ points_list_card.pointsDuelCommander }}{% if points_list_card.pointsDuelCommander > 0 %}</strong>{% endif %}
                                                    /
                                                    {% if points_list_card.pointsDuelCommanderSpecial > 0 %}<strong>{% endif %}{{ points_list_card.pointsDuelCommanderSpecial }}{% if points_list_card.pointsDuelCommanderSpecial > 0 %}</strong>{% endif %}
                                                </span>
                                            </td>
                                            <td>
                                                <span class="text-amber-300">
                                                    {% if points_list_card.pointsCommander > 0 %}<strong>{% endif %}{{ points_list_card.pointsCommander }}{% if points_list_card.pointsCommander > 0 %}</strong>{% endif %}
                                                    /
                                                    {% if points_list_card.pointsCommanderSpecial > 0 %}<strong>{% endif %}{{ points_list_card.pointsCommanderSpecial }}{% if points_list_card.pointsCommanderSpecial > 0 %}</strong>{% endif %}
                                                </span>
                                            </td>
                                            <td>
                                                <span class="text-emerald-300">
                                                    {% if points_list_card.points2hg > 0 %}<strong>{% endif %}{{ points_list_card.points2hg }}{% if points_list_card.points2hg > 0 %}</strong>{% endif %}
                                                    /
                                                    {% if points_list_card.points2hgSpecial > 0 %}<strong>{% endif %}{{ points_list_card.points2hgSpecial }}{% if points_list_card.points2hgSpecial > 0 %}</strong>{% endif %}
                                                </span>
                                            </td>
                                            <td>
                                                <span class="text-sky-300">
                                                    {% if points_list_card.pointsHighlander > 0 %}<strong>{% endif %}{{ points_list_card.pointsHighlander }}{% if points_list_card.pointsHighlander > 0 %}</strong>{% endif %}
                                                </span>
                                            </td>
                                            <td>
                                                <span class="text-sky-300">
                                                    {% if points_list_card.pointsModern > 0 %}<strong>{% endif %}{{ points_list_card.pointsModern }}{% if points_list_card.pointsModern > 0 %}</strong>{% endif %}
                                                </span>
                                            </td>
                                            <td>
                                                <span class="text-sky-300">
                                                    {% if points_list_card.pointsPioneer > 0 %}<strong>{% endif %}{{ points_list_card.pointsPioneer }}{% if points_list_card.pointsPioneer > 0 %}</strong>{% endif %}
                                                </span>
                                            </td>
                                            <td>
                                                <span class="text-sky-300">
                                                    {% if points_list_card.pointsStandard > 0 %}<strong>{% endif %}{{ points_list_card.pointsStandard }}{% if points_list_card.pointsStandard > 0 %}</strong>{% endif %}
                                                </span>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        {% endif %}
                    </td>
                </tr>
                <tr>
                    <th>{{ 'global.dates.label'|trans }}</th>
                    <td>
                        {{ points_list.createdAt ? points_list.createdAt|date('Y-m-d') : '' }} / {{ points_list.updatedAt ? points_list.updatedAt|date('Y-m-d') : '' }}
                    </td>
                </tr>
                <tr>
                    <th>{{ 'global.users.label'|trans }}</th>
                    <td>
                        {{ points_list.createdBy ? points_list.createdBy.username|raw : 'N/A' }} / {{ points_list.updatedBy ? points_list.updatedBy.username|raw : 'N/A' }}
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="flex flex-col gap-2 lg:flex-row lg:gap-4 w-full lg:justify-center my-2">
        <a class="btn btn-gray" href="{{ url('admin_mtg_points_list_index') }}" title="{{ 'global.indexbutton.title'|trans }}">{{ 'global.indexbutton.label'|trans }}</a>
        <a class="btn btn-blue" href="{{ url('admin_mtg_points_list_export', {'id': points_list.id}) }}" title="{{ 'global.export.title'|trans }}">{{ 'global.export.label'|trans }}</a>
        <a class="btn btn-blue" href="{{ url('admin_mtg_points_list_import', {'id': points_list.id}) }}" title="{{ 'global.import.title'|trans }}">{{ 'global.import.label'|trans }}</a>
        <a class="btn btn-green" href="{{ url('admin_mtg_points_list_edit', {'id': points_list.id}) }}" title="{{ 'global.editbutton.title'|trans }}">{{ 'global.editbutton.label'|trans }}</a>

        <div>
            {{ include('admin/mtg/points_list/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}
