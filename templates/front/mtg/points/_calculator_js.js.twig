    const deckList2BasepointsEl = root.querySelector('#decklist2-basepoints');
    const deckList3BasepointsEl = root.querySelector('#decklist3-basepoints');
    const deckList1ErrorsEl = root.querySelector('#decklist1-errors');
    const deckList2ErrorsEl = root.querySelector('#decklist2-errors');
    const deckList3ErrorsEl = root.querySelector('#decklist3-errors');
    const deckList1ModulationsEl = root.querySelector('#decklist1-modulations');
    const deckList2ModulationsEl = root.querySelector('#decklist2-modulations');
    const deckList3ModulationsEl = root.querySelector('#decklist3-modulations');
