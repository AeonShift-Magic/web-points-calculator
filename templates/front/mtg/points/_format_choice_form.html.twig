                                <span class="tooltip-item">
                                    <span class="icon-info"></span>
                                </span>
                                <span class="tooltip-content clearfix">
                                    <span class="tooltip-text">
                                        {{ 'front.mtg.quiz.question1.answer1.help'|trans|raw }}
                                    </span>
                                </span>
                            </span>
                        </label>
