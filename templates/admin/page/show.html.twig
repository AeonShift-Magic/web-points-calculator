{% extends 'admin/admin_layout.html.twig' %}

{% block title %}{{ 'admin.nav.pages.show.label'|trans({'page': page.title}) }}{% endblock %}

{% block body %}
    <h1>{{ 'admin.nav.pages.show.label'|trans({'page': page.title}) }}</h1>

    <div class="flex flex-col gap-2 lg:flex-row lg:gap-4 w-full lg:justify-center my-2">
        <a class="btn btn-gray" href="{{ url('admin_page_index') }}" title="{{ 'global.indexbutton.title'|trans }}">{{ 'global.indexbutton.label'|trans }}</a>
        <a class="btn btn-green" href="{{ url('admin_page_edit', {'id': page.id}) }}" title="{{ 'global.editbutton.title'|trans }}">{{ 'global.editbutton.label'|trans }}</a>

        <div>
            {{ include('admin/page/_delete_form.html.twig') }}
        </div>
    </div>

    <div class="table-wrapper">
        <table class="table center header-highlight-table">
            <tbody>
                <tr>
                    <th class="w-1/4">{{ 'global.id.label'|trans }}</th>
                    <td>{{ page.id }}</td>
                </tr>
                <tr>
                    <th>{{ 'admin.forms.page.create.title.label'|trans }}</th>
                    <td>{{ page.title }}</td>
                </tr>
                <tr>
                    <th>{{ 'admin.forms.page.create.zone.label'|trans }}</th>
                    <td>{{ ('page.position.' ~ page.zone ~ '.label')|trans }}</td>
                </tr>
                <tr>
                    <th>{{ 'admin.forms.page.create.language.label'|trans }}</th>
                    <td>{{ page.language|language_name }}</td>
                </tr>
                <tr>
                    <th>{{ 'admin.forms.page.create.weight.label'|trans }}</th>
                    <td>{{ page.weight }}</td>
                </tr>
                <tr>
                    <th>{{ 'admin.forms.page.create.slug.label'|trans }}</th>
                    <td>{{ page.slug }}</td>
                </tr>
                <tr>
                    <th>{{ 'admin.forms.page.create.contents.label'|trans }}</th>
                    <td class="text-left">{{ page.contents|raw }}</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="flex flex-col gap-2 lg:flex-row lg:gap-4 w-full lg:justify-center my-2">
        <a class="btn btn-gray" href="{{ url('admin_page_index') }}" title="{{ 'global.indexbutton.title'|trans }}">{{ 'global.indexbutton.label'|trans }}</a>
        <a class="btn btn-green" href="{{ url('admin_page_edit', {'id': page.id}) }}" title="{{ 'global.editbutton.title'|trans }}">{{ 'global.editbutton.label'|trans }}</a>

        <div>
            {{ include('admin/page/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}
