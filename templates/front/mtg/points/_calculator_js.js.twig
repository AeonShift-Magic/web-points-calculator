/**
 * @typedef {Object} CurrentFormatChoiceValues
 *
 * @property {string} [players]
 *   Selected value for the "players" group.
 *
 * @property {string} [copies]
 *   Selected value for the "copies" group.
 *
 * @property {string} [structure]
 *   Selected value for the "structure" group.
 *
 * @property {string} [commander]
 *   Selected value for the "commander" group.
 *
 * @property {string} [timeline]
 *   Selected value for the "timeline" group.
 *
 * @property {string} [pvalue]
 *   Selected primary value.
 *
 * @property {string} [mvalue]
 *   Selected secondary value.
 *
 * @property {string|number|undefined} update
 *   Current value of the update select element.
 */

document.addEventListener('DOMContentLoaded', () => {
    const root = document.getElementById('calculator-form');
    if (!root) {
        return;
    }

    /**
     * The slug of the current page.
     *
     * @type {string}
     */
    const slug = window.location.pathname.replace(/\/+$/, '').split('/').pop();

    // Messages, localized
    const MESSAGES = {
        containsinvalidtimelinecards: '{{ 'front.mtg.form.results.errors.containsinvalidtimelinecards.text'|trans|raw }}',
