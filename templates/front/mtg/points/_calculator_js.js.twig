            values: { players: 'multiffa', copies: 'singleton', structure: 'highlander', commander: 'yes', timeline: 'eternal' },
            slugs: ['aeonshift-commander']
        },
        {
            key: 'team-trio-duel-commander',
            title: '★ AeonShift Team Trio Duel Commander',
            values: { players: 'teamtrio', copies: 'singleton', structure: 'highlander', commander: 'yes', timeline: 'eternal' },
            slugs: ['aeonshift-team-trio-duel-commander']
        },
        {
            key: 'team-trio-eternal',
            title: '★ AeonShift Team Trio Eternal',
            values: { players: 'teamtrio', copies: 'quadruples', structure: 'mtg', commander: 'no', timeline: 'modern' },
