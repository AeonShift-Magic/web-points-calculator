<?xml version="1.0"?>
<psalm
        xmlns="https://getpsalm.org/schema/config"
        errorLevel="8"
        resolveFromConfigFile="true"
        showInfo="false"
>
    <projectFiles>
        <directory name="src"/>
        <ignoreFiles>
            <!-- Don't scan the vendor dir, this is normally totally ignored ;) -->
            <directory name="vendor" />
            <!-- Don't scan the tests dir: Psalm gets lost with PHPUnit, this is normally totally ignored -->
            <directory name="tests" />
            <!-- PHP 8.4 is not yet fully supported by Psalm -->
            <file name="src/Entity/CardInterface.php" />
            <file name="src/Entity/UpdateInterface.php" />
            <file name="src/Entity/PointsListInterface.php" />
            <file name="src/Entity/MTG/MTGCardInterface.php" />
        </ignoreFiles>
    </projectFiles>
    <issueHandlers>
        <PossiblyUnusedMethod errorLevel="suppress" />
        <PossiblyUnusedParam errorLevel="suppress" />
        <UnusedClass errorLevel="suppress" />
        <UnusedParam errorLevel="suppress" />
        <!-- Doctrine entities are often not final and have false-positively-reported unused properties -->
        <ClassMustBeFinal>
            <errorLevel type="suppress">
                <directory name="src/Entity" />
                <directory name="src/Repository" />
            </errorLevel>
        </ClassMustBeFinal>
        <PossiblyUnusedProperty>
            <errorLevel type="suppress">
                <directory name="src/Entity" />
            </errorLevel>
        </PossiblyUnusedProperty>
        <UnusedProperty>
            <errorLevel type="suppress">
                <directory name="src/Entity" />
            </errorLevel>
        </UnusedProperty>
        <PropertyNotSetInConstructor>
            <errorLevel type="suppress">
                <directory name="src/Entity" />
                <referencedProperty name="Symfony\Bundle\FrameworkBundle\Controller\AbstractController::$container" />
            </errorLevel>
        </PropertyNotSetInConstructor>
        <PossiblyUnusedReturnValue>
            <errorLevel type="suppress">
                <file name="src/Entity/SourceActivityHistoryInterface.php" />
            </errorLevel>
        </PossiblyUnusedReturnValue>
    </issueHandlers>
    <plugins>
        <pluginClass xmlns="https://getpsalm.org/schema/config" class="Weirdan\DoctrinePsalmPlugin\Plugin" />
    </plugins>
</psalm>
