    // What to look for, even with partner abilities, at best, among a decklist
    const MAX_COMMAND_ZONES = 2;

    // Regex to identify a card in a decklist
    const DECKLIST_CARD_LINE_REGEX = /^(\d+)[xX]?\s+(.+?)(?=\s+\([A-Za-z0-9]+\)\s+\d|\s*$)/;

    /**
     * The form keys that are allowed to be set by the user.
     *
     * @type {Set<string>}
     */
    const ALLOWED_FORM_KEYS = new Set([
        'players',
        'copies',
        'structure',
        'commander',
        'timeline',
        'pvalue',
        'mvalue',
        'update',
        'deckList1',
        'deckList2',
        'deckList3'
    ]);

