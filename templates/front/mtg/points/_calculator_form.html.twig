                    </div>
                    <div class="w-full lg:w-2/3">
                        <div class="switch-field">
                            <input type="radio" name="players" value="duel" id="players-duel" data-name-part="Duel" checked>
                            <label for="players-duel">
                                {{ 'front.mtg.quiz.question1.answer1.label'|trans }}
