                    // Highlander P-Values if duel or team trio
                    if (currentFormatChoiceValues.pvalue === 'standard' && 'highlanderStandardPlay' in pvalues) {
                        pvalue = pvalues.highlanderStandardPlay;
                    } else if (currentFormatChoiceValues.pvalue === 'lite' && 'highlanderLitePlay' in pvalues) {
                        pvalue = pvalues.highlanderLitePlay;
                    } else if (currentFormatChoiceValues.pvalue === 'power' && 'highlanderPowerPlay' in pvalues) {
                        pvalue = pvalues.highlanderPowerPlay;
                    }
                } else if (currentFormatChoiceValues.players === 'multiffa') {
                    // Commander / CEDH values for multiplayer without Command Zones
                    if (currentFormatChoiceValues.pvalue === 'standard' && 'commanderStandardPlay' in pvalues) {
                        pvalue = pvalues.commanderStandardPlay;
                    } else if (currentFormatChoiceValues.pvalue === 'lite' && 'commanderLitePlay' in pvalues) {
                        pvalue = pvalues.commanderLitePlay;
                    } else if (currentFormatChoiceValues.pvalue === 'power' && 'commanderPowerPlay' in pvalues) {
                        pvalue = pvalues.commanderPowerPlay;
                    }
                }
            }

        } else if (currentFormatChoiceValues.copies === 'quadruples') {
            // Quadruples P-Values

            // Default
            if (currentFormatChoiceValues.pvalue === 'standard' && 'baseQuadruplesStandardPlay' in pvalues) {
                pvalue = pvalues.baseQuadruplesStandardPlay;
            } else if (currentFormatChoiceValues.pvalue === 'lite' && 'baseQuadruplesLitePlay' in pvalues) {
                pvalue = pvalues.baseQuadruplesLitePlay;
            } else if (currentFormatChoiceValues.pvalue === 'power' && 'baseQuadruplesPowerPlay' in pvalues) {
                pvalue = pvalues.baseQuadruplesPowerPlay;
            }

            // Overload if modern, pioneer, or standard
            if (currentFormatChoiceValues.timeline === 'modern') {
                if (currentFormatChoiceValues.pvalue === 'standard' && 'modernStandardPlay' in pvalues) {
                    pvalue = pvalues.modernStandardPlay;
                } else if (currentFormatChoiceValues.pvalue === 'lite' && 'modernLitePlay' in pvalues) {
                    pvalue = pvalues.modernLitePlay;
                } else if (currentFormatChoiceValues.pvalue === 'power' && 'modernPowerPlay' in pvalues) {
                    pvalue = pvalues.modernPowerPlay;
                }
            } else if (currentFormatChoiceValues.timeline === 'pioneer') {
                if (currentFormatChoiceValues.pvalue === 'standard' && 'pioneerStandardPlay' in pvalues) {
                    pvalue = pvalues.pioneerStandardPlay;
                } else if (currentFormatChoiceValues.pvalue === 'lite' && 'pioneerLitePlay' in pvalues) {
                    pvalue = pvalues.pioneerLitePlay;
                } else if (currentFormatChoiceValues.pvalue === 'power' && 'pioneerPowerPlay' in pvalues) {
                    pvalue = pvalues.pioneerPowerPlay;
                }
            } else if (currentFormatChoiceValues.timeline === 'standard') {
                if (currentFormatChoiceValues.pvalue === 'standard' && 'standardStandardPlay' in pvalues) {
                    pvalue = pvalues.standardStandardPlay;
                } else if (currentFormatChoiceValues.pvalue === 'lite' && 'standardLitePlay' in pvalues) {
                    pvalue = pvalues.standardLitePlay;
                } else if (currentFormatChoiceValues.pvalue === 'power' && 'standardPowerPlay' in pvalues) {
                    pvalue = pvalues.standardPowerPlay;
                }
            }
        }
    }

    return Number.parseInt(pvalue);
}

/**
 * Finds a card by name in the current update points list.
 * Resolution order:
 * 1. Exact match
 * 2. Flavor-of resolution
 * 3. Alternate-name resolution (reverse lookup)
 * 4. Unranked fallback
 *
 * @param {string} name
 * @param {CurrentFormatChoiceValues} currentFormatChoiceValues
 * @returns {Object|null}
 */
function MTGPointsListModelV1FindCardByNameInUpdatePointsList(name, currentFormatChoiceValues) {
    if (
        typeof name !== 'string' ||
        !name ||
        !currentFormatChoiceValues ||
        typeof currentFormatChoiceValues.update === 'undefined'
    ) {
        return null;
    }

    const cards =
        updates?.updates?.[currentFormatChoiceValues.update]
            ?.pointsList?.cards;

    if (!cards || typeof cards !== 'object') {
        return null;
    }

    const normalizedName = name.normalize('NFC');

    // Exact match
    if (normalizedName in cards) {
        const card = cards[normalizedName];

        // Flavor-of resolution
        if (
            typeof card.flavorofnameen === 'string' &&
            card.flavorofnameen in cards
        ) {
            const baseCard = cards[card.flavorofnameen];

            return {
                name: card.flavorofnameen,
                ...baseCard
            };
        }

        return {
            name: normalizedName,
            ...card
        };
    }

    // Alternate-name reverse lookup
    for (const cardKey in cards) {
        if (!Object.hasOwn(cards, cardKey)) continue;
        if (cards[cardKey].alternatenameen === normalizedName) {

            return {
                name: cardKey,
                ...cards[cardKey]
            };
        }
    }

    // Unranked fallback
    const unrankedCard =
        MTGPointsListModelV1FindUnrankedCardInUpdatePointsList(
            currentFormatChoiceValues
        );

    if (unrankedCard !== null) {
        return {
            name: '((unranked))',
            ...unrankedCard
        };
    }

    return null;
}

/**
 * Finds a card by name in the current update points list.
 *
 * @param {CurrentFormatChoiceValues} currentFormatChoiceValues
 *
 * @returns {Object|null}
 */
function MTGPointsListModelV1FindUnrankedCardInUpdatePointsList(currentFormatChoiceValues) {
    if (
        !currentFormatChoiceValues ||
        typeof currentFormatChoiceValues.update === 'undefined'
    ) {
        return null;
    }

    const unranked =
        updates?.updates?.[currentFormatChoiceValues.update]
            ?.pointsList?.unranked;

    if (!unranked || typeof unranked !== 'object') {
        return null;
    }

    return unranked;
}

/**
 * Returns the points for an unranked card in the chosen update points list and format parameters.
 *
 * @param {Object} pointsList
 * @param {CurrentFormatChoiceValues} currentFormatChoiceValues
 * @param {string} deckZone
 * @returns {Number}
 */
function MTGPointsListModelGetPointsForUnrankedCardInList(pointsList, currentFormatChoiceValues, deckZone) {
    const zone = typeof deckZone === 'string' ? deckZone : 'maindeck';

    const contextKey = [
        currentFormatChoiceValues?.update,
        currentFormatChoiceValues?.players,
        currentFormatChoiceValues?.copies,
        currentFormatChoiceValues?.structure,
        currentFormatChoiceValues?.commander,
        currentFormatChoiceValues?.timeline,
        currentFormatChoiceValues?.pvalue,
        currentFormatChoiceValues?.mvalue,
        zone
    ].join('|');

    if (typeof MTGPointsListModelV1UnrankedListCardPointsByContext[contextKey] === 'number') {
        return MTGPointsListModelV1UnrankedListCardPointsByContext[contextKey];
    }

    let computed = null;

    // First, let's check integrity against the current update from the form
    if (
        typeof pointsList === 'object'
        && pointsList !== null
        && 'unranked' in pointsList
        && ['players', 'copies', 'structure', 'commander', 'timeline', 'pvalue', 'mvalue', 'update'].every(
            key => key in currentFormatChoiceValues
        )
    ) {
        const unranked = pointsList.unranked;

        if (currentFormatChoiceValues.copies === 'singleton') {
            // Default
            if ('pointsBaseSingleton' in unranked && unranked.pointsBaseSingleton !== null && unranked.pointsBaseSingleton !== '') {
                computed = unranked.pointsBaseSingleton;
            }

            if (currentFormatChoiceValues.commander === 'yes') {
                if (currentFormatChoiceValues.players === 'duel' || currentFormatChoiceValues.players === 'teamtrio') {
                    if (zone === 'commandzone') {
                        if ('pointsDuelCommanderSpecial' in unranked && unranked.pointsDuelCommanderSpecial !== null && unranked.pointsDuelCommanderSpecial !== '') {
                            computed = unranked.pointsDuelCommanderSpecial;
                        }
                    } else {
                        if ('pointsDuelCommander' in unranked && unranked.pointsDuelCommander !== null && unranked.pointsDuelCommander !== '') {
                            computed = unranked.pointsDuelCommander;
                        }
                    }
                } else if (currentFormatChoiceValues.players === 'multiffa') {
                    if (zone === 'commandzone') {
                        if ('pointsCommanderSpecial' in unranked && unranked.pointsCommanderSpecial !== null && unranked.pointsCommanderSpecial !== '') {
                            computed = unranked.pointsCommanderSpecial;
                        }
                    } else {
                        if ('pointsCommander' in unranked && unranked.pointsCommander !== null && unranked.pointsCommander !== '') {
                            computed = unranked.pointsCommander;
                        }
                    }
                }
            } else if (currentFormatChoiceValues.commander === 'no') {
                if (currentFormatChoiceValues.players === 'duel' || currentFormatChoiceValues.players === 'teamtrio') {
                    if ('pointsHighlander' in unranked && unranked.pointsHighlander !== null && unranked.pointsHighlander !== '') {
                        computed = unranked.pointsHighlander;
                    }
                } else if (currentFormatChoiceValues.players === 'multiffa') {
                    if ('pointsCommander' in unranked && unranked.pointsCommander !== null && unranked.pointsCommander !== '') {
                        computed = unranked.pointsCommander;
                    }
                }
            }
        } else if (currentFormatChoiceValues.copies === 'quadruples') {
            // Default
            if ('pointsBaseQuadruples' in unranked && unranked.pointsBaseQuadruples !== null && unranked.pointsBaseQuadruples !== '') {
                computed = unranked.pointsBaseQuadruples;
            }

            if (currentFormatChoiceValues.timeline === 'modern') {
                if ('pointsModern' in unranked && unranked.pointsModern !== null && unranked.pointsModern !== '') {
                    computed = unranked.pointsModern;
                }
            } else if (currentFormatChoiceValues.timeline === 'pioneer') {
                if ('pointsPioneer' in unranked && unranked.pointsPioneer !== null && unranked.pointsPioneer !== '') {
                    computed = unranked.pointsPioneer;
                }
            } else if (currentFormatChoiceValues.timeline === 'standard') {
                if ('pointsStandard' in unranked && unranked.pointsStandard !== null && unranked.pointsStandard !== '') {
                    computed = unranked.pointsStandard;
                }
            }
        }
    }

    const result = Number.parseInt(computed ?? '0');
    MTGPointsListModelV1UnrankedListCardPointsByContext[contextKey] = result;
    return result;
}

/**
 * Show card image under cursor when hovering links with a non-empty data-imageurl attribute.
 * Performance notes:
 * - uses pointer events (covers mouse + touch/pen)
 * - only runs move logic while a preview is active
 * - coalesces move events via requestAnimationFrame
 * - avoids repeated DOM queries/styles when nothing changes
 */
document.addEventListener('DOMContentLoaded', () => {
    /** @type {HTMLImageElement|null} */
    let hoverImgEl = null;
    /** @type {HTMLAnchorElement|null} */
    let activeLinkEl = null;
    /** @type {string} */
    let activeUrl = '';

    let rafId = 0;
    let lastX = 0;
    let lastY = 0;

    const ensureHoverImg = () => {
        if (hoverImgEl) return hoverImgEl;

        hoverImgEl = document.createElement('img');
        hoverImgEl.alt = '';
        hoverImgEl.decoding = 'async';
        hoverImgEl.loading = 'eager';
        hoverImgEl.classList.add('mtg-card-hover-image');
        hoverImgEl.style.position = 'fixed';
        hoverImgEl.style.left = '0';
        hoverImgEl.style.top = '0';
        hoverImgEl.style.transform = 'translate3d(-9999px, -9999px, 0)';
        hoverImgEl.style.pointerEvents = 'none';
        hoverImgEl.style.zIndex = '999999';
        hoverImgEl.style.maxWidth = '260px';
        hoverImgEl.style.maxHeight = '360px';
        hoverImgEl.style.background = '#111';
        document.body.appendChild(hoverImgEl);

        return hoverImgEl;
    };

    const hideHoverImg = () => {
        activeLinkEl = null;
        activeUrl = '';

        if (rafId) {
            cancelAnimationFrame(rafId);
            rafId = 0;
        }

        if (hoverImgEl) {
            hoverImgEl.style.transform = 'translate3d(-9999px, -9999px, 0)';
        }
    };

    const scheduleReposition = () => {
        if (!hoverImgEl || !activeLinkEl) return;
        if (rafId) return;

        rafId = requestAnimationFrame(() => {
            rafId = 0;
            if (!hoverImgEl || !activeLinkEl) return;

            const offsetX = 14;
            const offsetY = 18;

            const rect = hoverImgEl.getBoundingClientRect();
            const viewportW = window.innerWidth;
            const viewportH = window.innerHeight;

            let x = lastX + offsetX;
            let y = lastY + offsetY;

            // Keep inside viewport
            if (x + rect.width > viewportW - 8) x = viewportW - rect.width - 8;
            if (y + rect.height > viewportH - 8) y = viewportH - rect.height - 8;
            if (x < 8) x = 8;
            if (y < 8) y = 8;

            hoverImgEl.style.transform = `translate3d(${ x }px, ${ y }px, 0)`;
        });
    };

    document.addEventListener('pointerover', (e) => {
        const target = e.target;
        if (!(target instanceof Element)) return;

        // Fast path: if the event target is itself a link, avoid closest()
        const link = (target instanceof HTMLAnchorElement)
            ? target
            : target.closest('a[data-imageurl]');

        if (!(link instanceof HTMLAnchorElement)) return;

        const url = (link.getAttribute('data-imageurl') || '').trim();
        if (!url) return;

        // If already active on same link+url, do nothing
        if (activeLinkEl === link && activeUrl === url) return;

        const img = ensureHoverImg();
        activeLinkEl = link;
        activeUrl = url;

        if (img.src !== url) {
            img.src = url;
        }

        lastX = e.clientX;
        lastY = e.clientY;
        scheduleReposition();
    }, true);

    document.addEventListener('pointermove', (e) => {
        if (!activeLinkEl || !hoverImgEl) return;

        lastX = e.clientX;
        lastY = e.clientY;
        scheduleReposition();
    }, { capture: true, passive: true });

    document.addEventListener('pointerout', (e) => {
        if (!activeLinkEl) return;

        const target = e.target;
        if (!(target instanceof Element)) return;

        const fromLink = (target instanceof HTMLAnchorElement)
            ? target
            : target.closest('a[data-imageurl]');

        if (fromLink !== activeLinkEl) return;

        // If moving to another element inside the same link, keep showing
        const related = e.relatedTarget;
        if (related instanceof Node && activeLinkEl.contains(related)) return;

        hideHoverImg();
    }, true);

    // Hide on scroll/blur to avoid "stuck" previews
    window.addEventListener('scroll', hideHoverImg, { passive: true });
    window.addEventListener('blur', hideHoverImg);
});
