     */
    const PRESETS = [
        // Printed timeline
        {
            key: 'printed',
            title: '★ AeonShift All-Time',
            values: { players: 'duel', copies: 'quadruples', structure: 'mtg', commander: 'no', timeline: 'printed' },
            slugs: ['aeonshift-printed']
        },
        {
            key: 'printed-duel-commander',
            title: '★ AeonShift All-Time Duel Commander',
            values: { players: 'duel', copies: 'singleton', structure: 'highlander', commander: 'yes', timeline: 'printed' },
            slugs: ['aeonshift-printed-duel-commander']
        },
        {
            key: 'printed-commander',
            title: '★ AeonShift All-Time Commander (or cEDH)',
            values: { players: 'multiffa', copies: 'singleton', structure: 'highlander', commander: 'yes', timeline: 'printed' },
            slugs: ['aeonshift-printed-commander']
        },
        {
            key: 'printed-highlander',
            title: '★ AeonShift All-Time Highlander',
            values: { players: 'duel', copies: 'singleton', structure: 'highlander', commander: 'no', timeline: 'printed' },
            slugs: ['aeonshift-printed-highlander']
        },
        // Funny timeline
        {
            key: 'eternal',
            title: '★ AeonShift Funny',
            values: { players: 'duel', copies: 'quadruples', structure: 'mtg', commander: 'no', timeline: 'funny' },
            slugs: ['aeonshift-funny']
        },
        {
            key: 'funny-duel-commander',
            title: '★ AeonShift Funny Duel Commander',
            values: { players: 'duel', copies: 'singleton', structure: 'highlander', commander: 'yes', timeline: 'funny' },
            slugs: ['aeonshift-funny-duel-commander']
        },
        {
            key: 'funny-commander',
            title: '★ AeonShift Funny Commander (or cEDH)',
            values: { players: 'multiffa', copies: 'singleton', structure: 'highlander', commander: 'yes', timeline: 'funny' },
            slugs: ['aeonshift-funny-commander']
        },
        {
            key: 'funny-highlander',
            title: '★ AeonShift Funny Highlander',
            values: { players: 'duel', copies: 'singleton', structure: 'highlander', commander: 'no', timeline: 'funny' },
            slugs: ['aeonshift-funny-highlander']
