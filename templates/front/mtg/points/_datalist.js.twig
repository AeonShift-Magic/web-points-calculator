// DataList styling
(() => {
    const MAX_RESULTS = 30;
    const MIN_CHARS = 1;
    const DEBOUNCE_MS = 60;

    let openDropdown = null;

    const getTarget = (evt) => evt && evt.target;

    const ensureIndex = (list) => {
        if (!list) return null;
        if (list._asIndex) return list._asIndex;

        const options = Array.from(list.getElementsByTagName('option'));
        const values = new Array(options.length);
        const valuesLC = new Array(options.length);

        for (let i = 0; i < options.length; i++) {
            const opt = options[i];
            const raw = (opt.value && opt.value.length)
                ? opt.value
                : (opt.getAttribute('value') || opt.textContent || '').trim();

            values[i] = raw;
            valuesLC[i] = String(raw).toLowerCase();
        }

        list._asIndex = { values, valuesLC };
        return list._asIndex;
    };

    const ensureDropdown = (input) => {
        if (input._asDropdown) return input._asDropdown;

        const dd = document.createElement('div');
        dd.setAttribute('hidden', '');
        dd.classList.add('datalist-div');

        const host = input.parentElement || document.body;
        const hostStyle = window.getComputedStyle(host);
        if (hostStyle.position === 'static') host.style.position = 'relative';
        host.appendChild(dd);

        dd.input = input;
        input._asDropdown = dd;

        dd.addEventListener('mousedown', (e) => {
            const item = e.target && (e.target.closest ? e.target.closest('[data-value]') : null);
            if (!item) return;

            if (item.hasAttribute('data-disabled')) return;

            e.preventDefault();

            dd._suppressNextOpen = true;

            input.value = item.getAttribute('data-value') || '';

            hideDropdown(dd);

            input.dispatchEvent(new Event('input', { bubbles: true }));
            input.dispatchEvent(new Event('change', { bubbles: true }));

            input.focus();
        });

        return dd;
    };

    const hideDropdown = (dd) => {
        if (!dd) return;
        dd.style.display = 'none';
        dd._open = false;
        if (openDropdown === dd) openDropdown = null;
    };

    const showDropdown = (input, dd) => {
        if (openDropdown && openDropdown !== dd) hideDropdown(openDropdown);
        dd.style.display = 'block';
        dd._open = true;
        openDropdown = dd;
    };

    const getSelectableItems = (dd) => {
        if (!dd) return [];
        const all = Array.from(dd.querySelectorAll('[data-value]'));
        return all.filter((el) => !el.hasAttribute('data-disabled'));
    };

    const setActiveIndex = (dd, index, { syncValue = false } = {}) => {
        const items = getSelectableItems(dd);
        if (!items.length) {
            dd._activeIndex = -1;
            return;
        }

        const next = Math.max(0, Math.min(index, items.length - 1));
        dd._activeIndex = next;

        for (let i = 0; i < items.length; i++) {
            items[i].classList.toggle('datalist-option-active', i === next);
        }

        const active = items[next];
        if (active && typeof active.scrollIntoView === 'function') {
            active.scrollIntoView({ block: 'nearest' });
        }

        if (syncValue && dd.input) {
            dd.input.value = active.getAttribute('data-value') || '';
        }
    };

    const renderResults = (dd, results, input) => {
        dd.textContent = '';

        if (!results || !results.length) {
            dd._activeIndex = -1;

            const item = document.createElement('div');
            item.setAttribute('data-disabled', '1');
            item.classList.add('datalist-option', 'datalist-option-no-results');
            item.textContent = '{{ 'front.mtg.form.decklist.noresult.label'|trans|raw }}';
            dd.appendChild(item);
            return;
        }

        var calculatorJsFunctionPrefix;

        for (let i = 0; i < results.length; i++) {
            const cardName = results[i];

            const item = document.createElement('div');
            item.setAttribute('data-value', cardName);
            item.classList.add('datalist-option');
            let textContent = '';

            if (typeof window.AeonShiftCalculator.getCurrentFormatChoiceValues === 'function' && typeof input.dataset.forzone === 'string') {
                let currentFormatChoiceValues = window.AeonShiftCalculator.getCurrentFormatChoiceValues();

                if (
                    updates
                    && updates?.updates !== undefined
                    && updates.updates[currentFormatChoiceValues.update] !== undefined
                    && updates?.updates?.[currentFormatChoiceValues.update]?.pointsList !== undefined
                    && updates?.updates?.[currentFormatChoiceValues.update]?.pointsList?.calculatorJsFunctionPrefix !== undefined
                    && ['players', 'copies', 'structure', 'commander', 'timeline', 'pvalue', 'mvalue', 'update'].every(key => key in currentFormatChoiceValues)
                ) {
                    calculatorJsFunctionPrefix = updates?.updates?.[currentFormatChoiceValues.update]?.pointsList?.calculatorJsFunctionPrefix;

                    if (
                        typeof calculatorJsFunctionPrefix === 'string'
                        && typeof window[calculatorJsFunctionPrefix + 'CalculatePointsForCardInPointsList'] === 'function'
                    ) {
                        const currentPointsValue = window[calculatorJsFunctionPrefix + 'CalculatePointsForCardInPointsList'](
                            cardName,
                            updates?.updates?.[currentFormatChoiceValues.update]?.pointsList,
                            currentFormatChoiceValues,
                            input.dataset.forzone
                        );

                        if (typeof currentPointsValue.points !== 'undefined') {
                            if (currentPointsValue.points === 0) {
                                textContent = `${cardName} <span class="gray-text font-bold">(${currentPointsValue.points})</span>`;
                            } else if (currentPointsValue.points > 0) {
                                textContent = `${cardName} <span class="red-text font-bold">(-${currentPointsValue.points})</span>`;
                            } else {
                                textContent = `${cardName} <span class="green-text font-bold">(+${currentPointsValue.points})</span>`;
                            }
                        }
                    }
                }
            }

            if (textContent.length === 0) {
                textContent = cardName;
            }

            item.innerHTML = textContent;
            dd.appendChild(item);
        }

        dd._activeIndex = 0;
        setActiveIndex(dd, 0, { syncValue: false });
    };

    const searchTopN = (values, valuesLC, qLC) => {
        const out = [];

        for (let i = 0; i < valuesLC.length; i++) {
            if (valuesLC[i].includes(qLC)) {
                out.push(values[i]);
                if (out.length >= MAX_RESULTS) break;
            }
        }

        return out;
    };

    const onInputDebounced = (input) => {
        const list = input.datalist;
        if (!list) return;

        const dd = ensureDropdown(input);

        if (dd._suppressNextOpen) {
            dd._suppressNextOpen = false;
            hideDropdown(dd);
            return;
        }

        const q = String(input.value || '').trim();
        if (q.length < MIN_CHARS) {
            hideDropdown(dd);
            return;
        }

        const idx = ensureIndex(list);
        const qLC = q.toLowerCase();

        const results = searchTopN(idx.values, idx.valuesLC, qLC);

        renderResults(dd, results, input);
        showDropdown(input, dd);
    };

    document.body.addEventListener('focusin', (evt) => {
        const input = getTarget(evt);
        if (!input) return;

        if (input.list && !input._datalistWired) {
            const list = input.list;
            input.datalist = list;

            input.removeAttribute('list');
            list.style.display = 'none';

            input._datalistWired = true;

            let timer = 0;

            input.addEventListener('input', () => {
                if (timer) clearTimeout(timer);
                timer = window.setTimeout(() => onInputDebounced(input), DEBOUNCE_MS);
            });

            input.addEventListener('blur', () => {
                const dd = input._asDropdown;
                setTimeout(() => hideDropdown(dd), 0);
            });

            input.addEventListener('keydown', (e) => {
                const dd = input._asDropdown;

                if (e.key === 'Escape' || e.keyCode === 27) {
                    hideDropdown(dd);
                    return;
                }

                if (!dd || !dd._open) return;

                if (e.key === 'ArrowDown' || e.keyCode === 40) {
                    e.preventDefault();
                    const cur = typeof dd._activeIndex === 'number' ? dd._activeIndex : -1;
                    setActiveIndex(dd, cur + 1, { syncValue: true });
                    return;
                }

                if (e.key === 'ArrowUp' || e.keyCode === 38) {
                    e.preventDefault();
                    const cur = typeof dd._activeIndex === 'number' ? dd._activeIndex : 0;
                    setActiveIndex(dd, cur - 1, { syncValue: true });
                    return;
                }

                if (e.key === 'Enter' || e.keyCode === 13) {
                    const items = getSelectableItems(dd);
                    const idx = typeof dd._activeIndex === 'number' ? dd._activeIndex : -1;
                    const active = items[idx];
                    if (!active) return;

                    e.preventDefault();

                    dd._suppressNextOpen = true;

                    input.value = active.getAttribute('data-value') || '';
                    hideDropdown(dd);

                    input.dispatchEvent(new Event('input', { bubbles: true }));
                    input.dispatchEvent(new Event('change', { bubbles: true }));
                }
            });
        }
    });
})();
