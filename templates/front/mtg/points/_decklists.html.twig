{# Decklist textareas #}
<div class="flex flex-col w-full justify-around items-start">

    {# Decklist 1 #}
    <div class="flex flex-col lg:flex-row w-full justify-around items-start mt-4" id="decklist-container-1">
        <div class="w-full lg:w-1/3 py-4">
            <div class="mb-8 pr-4">
                <label for="decklist1">{{ 'front.mtg.form.decklist1.label'|trans }}</label>
                <textarea class="decklist-cards" rows="30" cols="30" id="decklist1" placeholder="{{ 'front.mtg.form.decklist1.placeholder'|trans|raw }}"></textarea>
                <div class="mt-1 help-text">{{ 'front.mtg.form.decklist1.help'|trans|raw }}</div>
            </div>
        </div>
        <div class="w-full lg:w-2/3 py-4">
            <div class="pt-6 pl-4">
                <div class="text-3xl inline-block w-full mb-4 blue-text uppercase" id="total1">
                    <span class="icon-bullseye"></span>{{ 'front.mtg.form.results.decklist1.label'|trans }}</div>
                <div class="text-xl inline-block w-full mt-3 mb-6 green-text" id="decklist1-legal">
                    <span class="icon-ok m-0"></span> {{ 'front.mtg.form.results.legal.yes.label'|trans|raw }}
                </div>
                <div class="text-xl w-full mt-3 mb-6 red-text hidden" id="decklist1-illegal">
                    <span class="icon-cancel"></span> {{ 'front.mtg.form.results.legal.no.label'|trans|raw }}
                </div>
                <div class="text-xl w-full mt-3 mb-6 red-text hidden" id="decklist1-errors"></div>

                <div class="text-xl inline-flex w-full my-2 blue-text uppercase">&darr; {{ 'front.mtg.form.results.breakdown.title'|trans|raw }}</div>

                <div class="dark-alt-background my-2 text-lg w-full inline-flex flex-col lg:flex-row justify-between rounded-lg p-3">
                    <span class="inline-block w-full lg:w-1/2">
                        <span class="tooltip">
                            <span class="tooltip-item">
                                <span class="icon-info"></span>
                            </span>
                            <span class="tooltip-content clearfix">
                                <span class="tooltip-text">
                                    {{ 'front.mtg.form.results.breakdown.basepoints.help'|trans|raw }}
                                </span>
                            </span>
                        </span>
                        {{ 'front.mtg.form.results.breakdown.basepoints.text'|trans|raw }}
                    </span>
                    <span class="inline-block w-full lg:w-1/2">
                        <span class="inline-block blue-text font-bold" id="decklist1-basepoints">{{ 'global.none.label'|trans }}</span>
                    </span>
                </div>

                <div class="dark-alt-background inline-flex flex-col lg:flex-row my-2 text-lg w-full rounded-lg p-3">
                    <div class="w-full lg:w-1/2">
                        <span class="tooltip">
                            <span class="tooltip-item">
                                <span class="icon-info"></span>
                            </span>
                            <span class="tooltip-content clearfix">
                                <span class="tooltip-text">
                                    {{ 'front.mtg.form.results.breakdown.modulations.help'|trans|raw }}
                                </span>
                            </span>
                        </span>
                        {{ 'front.mtg.form.results.breakdown.modulations.text'|trans|raw }}
                    </div>
                    <ul class="blue-text inline-block w-full lg:w-1/2" id="decklist1-modulations">
                        <li>{{ 'global.none.label'|trans }}</li>
                    </ul>
                </div>

                <div class="dark-alt-background inline-flex flex-col lg:flex-row my-2 text-lg w-full rounded-lg p-3">
                    <div class="w-full lg:w-1/2">
